<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/assets/global.css" />
  <style>
    :root { --navy:#0d2854; --blue:#1a3d6e; --sky:#38b6ff; --accent:#ffde59; --accent2:#ff914d; --white:#fff; --offwhite:#F5F7FA; --text:#444443; --muted:#6b6b6a; --border:#cce8ff; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--offwhite); overflow-x: hidden; }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    .tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent2); margin-bottom: 12px; }

    nav#navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 2px solid var(--border); transition: box-shadow .3s; }
    nav#navbar.scrolled { box-shadow: 0 4px 24px rgba(13,40,84,.12); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 82px; }
    .nav-logo { display: flex; align-items: center; gap: 18px; text-decoration: none; flex-shrink: 0; margin-right: 140px; }
    .nav-logo-img { height: 56px; width: auto; display: block; object-fit: contain; }
    .nav-logo-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: #0d2854; white-space: nowrap; text-decoration: none; }
    .nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; }
    .nav-links > li { position: relative; }
    .nav-links > li > a { display: flex; align-items: center; gap: 5px; padding: 8px 14px; color: #0d2854; text-decoration: none; font-size: 1rem; font-weight: 600; border-radius: 6px; transition: background .2s, color .2s; white-space: nowrap; }
    .nav-links > li > a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-links > li.has-dropdown > a::after { content: ''; display: inline-block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; margin-left: 2px; transition: transform .2s; }
    .nav-links > li.has-dropdown:hover > a::after { transform: rotate(180deg); }
    .nav-dropdown { display: none; position: absolute; top: 100%; left: 0; min-width: 200px; background: #fff; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 8px 32px rgba(13,40,84,.12); padding: 8px 6px 6px; z-index: 1001; }
    .nav-links > li.has-dropdown:hover .nav-dropdown { display: block; }
    .nav-dropdown a { display: block; padding: 9px 14px; color: #0d2854; font-size: .95rem; font-weight: 600; text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
    .nav-dropdown a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
    .nav-hamburger span { display: block; width: 22px; height: 2px; background: #0d2854; border-radius: 2px; transition: .3s; }
    .mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(13,40,84,.98); flex-direction: column; align-items: center; justify-content: center; gap: 24px; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { color: #fff; font-size: 1.4rem; font-weight: 700; text-decoration: none; font-family: 'Playfair Display', serif; }
    @media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }

    .page-header { background: linear-gradient(135deg, #0d2854, #071229); padding: 60px 0 40px; margin-top: 82px; }
    .page-header .tag { color: var(--accent); }
    .page-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #fff; margin-bottom: 12px; }
    .page-header p { color: rgba(255,255,255,.7); font-size: 1.1rem; max-width: 700px; line-height: 1.7; }

    .content-section { padding: 64px 0; }
    .section-heading { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--navy); margin-bottom: 10px; }
    .section-sub { font-size: 1.05rem; color: var(--muted); line-height: 1.7; max-width: 680px; margin-bottom: 40px; }

    .coordinator-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .coordinator-card {
      background: var(--white); border: 1px solid var(--border); border-radius: 16px;
      padding: 28px 24px; display: flex; align-items: flex-start; gap: 18px;
      transition: box-shadow .2s, transform .2s;
    }
    .coordinator-card:hover { box-shadow: 0 10px 32px rgba(13,40,84,.1); transform: translateY(-4px); }
    .coordinator-avatar {
      width: 56px; height: 56px; border-radius: 50%; flex-shrink: 0;
      background: linear-gradient(135deg, var(--navy), var(--sky));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: #fff;
      overflow: hidden;
    }
    .coordinator-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; display: block; }
    .coordinator-info { flex: 1; min-width: 0; }
    .coordinator-name { font-weight: 700; font-size: 1.05rem; color: var(--navy); margin-bottom: 2px; }
    .coordinator-role { font-size: .85rem; color: var(--sky); font-weight: 600; margin-bottom: 8px; }
    .coordinator-district { font-size: .9rem; color: var(--muted); margin-bottom: 10px; line-height: 1.5; }
    .coordinator-email { display: inline-flex; align-items: center; gap: 5px; font-size: .85rem; color: var(--blue); font-weight: 600; text-decoration: none; }
    .coordinator-email:hover { color: var(--sky); }

    .coming-soon { padding: 80px 0; text-align: center; }
    .coming-soon-icon { width: 80px; height: 80px; border-radius: 50%; background: rgba(56,182,255,.1); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--sky); margin: 0 auto 24px; }
    .coming-soon h2 { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--navy); margin-bottom: 12px; }
    .coming-soon p { font-size: 1.1rem; color: var(--muted); max-width: 520px; margin: 0 auto; line-height: 1.7; }

    footer { background: #070f1f; padding: 20px 0 12px; border-top: 1px solid rgba(255,255,255,.06); }
    .footer-bottom { display: flex; justify-content: center; color: rgba(255,255,255,.3); font-size: .82rem; padding: 8px 0; }
    .footer-bottom a { color: rgba(255,255,255,.4); text-decoration: none; }
  </style>
</head>
<body>

{% include "partials/nav.njk" %}
{% include "partials/dropdown-bar.njk" %}

<div class="page-header">
  <div class="container">
    <span class="tag">{{ header_tag }}</span>
    <h1>{{ header_h1 }}</h1>
    <p>{{ header_sub }}</p>
  </div>
</div>

<section class="content-section">
  <div class="container">
    <span class="tag">{{ section_tag }}</span>
    <h2 class="section-heading">{{ section_heading }}</h2>
    <p class="section-sub">{{ section_sub }}</p>

    {% if coordinators and coordinators.length %}
    <div class="coordinator-grid">
      {% for c in coordinators %}
      <div class="coordinator-card">
        <div class="coordinator-avatar">
          {% if c.photo %}<img src="{{ c.photo }}" alt="{{ c.name }}" />{% else %}{{ c.name | truncate(1, true, '') }}{% endif %}
        </div>
        <div class="coordinator-info">
          <div class="coordinator-name">{{ c.name }}</div>
          <div class="coordinator-role">{{ c.role }}</div>
          <div class="coordinator-district">{{ c.district }}</div>
          {% if c.email %}<a href="mailto:{{ c.email }}" class="coordinator-email"><i class="fa-solid fa-envelope"></i> {{ c.email }}</a>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="coming-soon">
      <div class="coming-soon-icon"><i class="fa-solid fa-people-group"></i></div>
      <h2>Coming Soon</h2>
      <p>Campaign coordinator information is being compiled. Check back soon to connect with your district coordinator.</p>
    </div>
    {% endif %}
  </div>
</section>

{% include "partials/footer.njk" %}

<script>
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
  });
  function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('open'); }
</script>
</body>
</html>
