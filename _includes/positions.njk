<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ meta_description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/assets/global.css" />
  <style>
    :root { --navy:#0d2854; --blue:#1a3d6e; --sky:#38b6ff; --accent:#ffde59; --accent2:#ff914d; --white:#fff; --offwhite:#F5F7FA; --text:#444443; --muted:#6b6b6a; --border:#cce8ff; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--offwhite); overflow-x: hidden; }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    .section { padding: 40px 0; }
    .section-alt { background: var(--white); }
    .tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent2); margin-bottom: 12px; }
    .section-sub { font-size: 1.1rem; color: var(--muted); max-width: 800px; line-height: 1.7; text-wrap: balance; }
nav#navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 2px solid var(--border); transition: box-shadow .3s; }
nav#navbar.scrolled { box-shadow: 0 4px 24px rgba(13,40,84,.12); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; height: 82px; }
.nav-logo { display: flex; align-items: center; gap: 18px; text-decoration: none; flex-shrink: 0; margin-right: 140px; }
.nav-logo-img { height: 56px; width: auto; display: block; object-fit: contain; }
.nav-logo-text { display: flex; flex-direction: column; line-height: 1.1; }
.nav-logo-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: #0d2854; white-space: nowrap; }
.nav-logo-sub { font-size: .8rem; font-weight: 600; color: var(--muted); white-space: nowrap; letter-spacing: .03em; }
.nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; }
.nav-links > li { position: relative; }
.nav-links > li > a { display: flex; align-items: center; gap: 5px; padding: 8px 14px; color: #0d2854; text-decoration: none; font-size: 1rem; font-weight: 600; border-radius: 6px; transition: background .2s, color .2s; white-space: nowrap; }
.nav-links > li > a:hover { background: var(--offwhite); color: #38b6ff; }
.nav-links > li.has-dropdown > a::after { content: ''; display: inline-block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; margin-left: 2px; transition: transform .2s; }
.nav-links > li.has-dropdown:hover > a::after { transform: rotate(180deg); }
.nav-dropdown { display: none; position: absolute; top: 100%; left: 0; min-width: 200px; background: #fff; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 8px 32px rgba(13,40,84,.12); padding: 8px 6px 6px; z-index: 1001; }
.nav-links > li.has-dropdown:hover .nav-dropdown { display: block; }
.nav-dropdown a { display: block; padding: 9px 14px; color: #0d2854; font-size: .95rem; font-weight: 600; text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
.nav-dropdown a:hover { background: var(--offwhite); color: #38b6ff; }
.nav-cta { background: #38b6ff !important; color: #fff !important; padding: 11px 24px !important; border-radius: 8px !important; font-weight: 700 !important; margin-left: 8px; }
.nav-cta:hover { background: #1ca8f5 !important; }
.nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
.nav-hamburger span { display: block; width: 22px; height: 2px; background: #0d2854; border-radius: 2px; transition: .3s; }
.mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(13,40,84,.98); flex-direction: column; align-items: center; justify-content: center; gap: 24px; }
.mobile-menu.open { display: flex; }
.mobile-menu a { color: #fff; font-size: 1.4rem; font-weight: 700; text-decoration: none; font-family: 'Playfair Display', serif; }
@media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }
    .page-header { background: linear-gradient(135deg, #0d2854, #071229); padding: 60px 0 28px; margin-top: 82px; }
    .page-header .tag { color: var(--accent); }
    .page-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #fff; margin-bottom: 12px; }
    .page-header p { color: rgba(255,255,255,.7); font-size: 1.1rem; max-width: 800px; line-height: 1.7; text-wrap: balance; }
    .positions-nav { background: var(--white); border-bottom: 1px solid var(--border); padding: 16px 0; position: sticky; top: 68px; z-index: 100; }
    .positions-nav-inner { display: flex; gap: 8px; flex-wrap: wrap; }
    .pos-nav-link { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 100px; color: var(--muted); font-size: .88rem; font-weight: 600; text-decoration: none; border: 1px solid var(--border); transition: background .2s, color .2s, border-color .2s; }
    .pos-nav-link:hover, .pos-nav-link.active { background: var(--navy); color: #fff; border-color: var(--navy); }
    .pos-nav-link i { font-size: .85rem; }
    .position-section { padding: 80px 0; border-bottom: 1px solid var(--border); }
    .position-section:last-child { border-bottom: none; }
    .position-section.section-alt { background: var(--white); }
    .position-header { display: flex; align-items: flex-start; gap: 28px; margin-bottom: 48px; }
    .position-big-icon { width: 80px; height: 80px; border-radius: 20px; background: linear-gradient(135deg, var(--navy), var(--blue)); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #fff; flex-shrink: 0; }
    .position-header-text h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .position-term-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,145,77,.12); border: 1px solid rgba(255,145,77,.3); color: var(--accent2); font-size: .82rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: 5px 12px; border-radius: 100px; }
    .position-body { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
    .position-description p { font-size: 1.05rem; color: var(--muted); line-height: 1.8; margin-bottom: 16px; }
    .responsibilities-card { background: var(--offwhite); border: 1px solid var(--border); border-radius: 14px; padding: 28px; }
    .responsibilities-card h4 { font-weight: 700; color: var(--navy); margin-bottom: 16px; font-size: 1rem; display: flex; align-items: center; gap: 8px; }
    .responsibilities-card h4 i { color: var(--sky); }
    .responsibility-item { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; font-size: .93rem; color: var(--muted); line-height: 1.5; }
    .responsibility-item:last-child { margin-bottom: 0; }
    .responsibility-item::before { content: '→'; color: var(--sky); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .comparison-table { width: 100%; border-collapse: collapse; margin-top: 48px; background: var(--white); border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
    .comparison-table th { background: var(--navy); color: #fff; padding: 16px 20px; text-align: left; font-size: .85rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; }
    .comparison-table td { padding: 14px 20px; border-bottom: 1px solid var(--border); font-size: .93rem; color: var(--muted); vertical-align: top; }
    .comparison-table tr:last-child td { border-bottom: none; }
    .comparison-table tr:nth-child(even) td { background: var(--offwhite); }
    .comparison-table .yes { color: #2a7a40; font-weight: 700; }
    .comparison-table .no { color: var(--muted); }
    .comparison-table td:first-child { color: var(--text); font-weight: 600; }
    .cta-strip { background: linear-gradient(135deg, var(--navy), #071229); padding: 40px 0; text-align: center; }
    .cta-strip h2 { font-family: 'Playfair Display', serif; color: #fff; font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 700; margin-bottom: 16px; }
    .cta-strip p { color: rgba(255,255,255,.65); font-size: 1.05rem; margin-bottom: 32px; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: var(--navy); font-weight: 700; font-size: 1rem; padding: 14px 28px; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 20px rgba(255,222,89,.35); transition: transform .2s, background .2s; margin: 6px; }
    .btn-primary:hover { transform: translateY(-2px); background: #ffd633; }
    .btn-secondary-light { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.1); color: #fff; font-weight: 600; font-size: 1rem; padding: 14px 28px; border-radius: 10px; text-decoration: none; border: 1px solid rgba(255,255,255,.25); transition: background .2s; margin: 6px; }
    .btn-secondary-light:hover { background: rgba(255,255,255,.18); }
    footer { background: #070f1f; padding: 20px 0 12px; border-top: 1px solid rgba(255,255,255,.06); }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,.08); margin-bottom: 14px; }
    .footer-brand p { color: rgba(255,255,255,.45); font-size: .85rem; line-height: 1.6; margin-top: 6px; max-width: 280px; }
    .footer-socials { display: flex; gap: 8px; margin-top: 10px; }
    .footer-social { width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,.07); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,.55); font-size: .9rem; text-decoration: none; transition: background .2s, color .2s; }
    .footer-social:hover { background: var(--sky); color: #fff; }
    .footer-col h4 { font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 8px; }
    .footer-col a { display: block; color: rgba(255,255,255,.6); font-size: .85rem; text-decoration: none; margin-bottom: 5px; transition: color .2s; }
    .footer-col a:hover { color: #fff; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; color: rgba(255,255,255,.3); font-size: .82rem; }
    .footer-bottom a { color: rgba(255,255,255,.4); text-decoration: none; }
    @media (max-width: 900px) { .position-body { grid-template-columns: 1fr; } .footer-inner { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } .position-header { flex-direction: column; } .footer-inner { grid-template-columns: 1fr; gap: 16px; } .footer-bottom { flex-direction: column; text-align: center; } }
  </style>
</head>
<body>

{% include "partials/nav.njk" %}

<div class="page-header">
  <div class="container">
    <span class="tag">{{ header_tag }}</span>
    <h1>{{ header_h1 }}</h1>
    <p>{{ header_subtitle }}</p>
  </div>
</div>

<!-- QUICK NAV -->
<div class="positions-nav">
  <div class="container">
    <div class="positions-nav-inner">
      {% for pos in positions %}
      <a href="#{{ pos.id }}" class="pos-nav-link"><i class="{{ pos.icon }}"></i> {{ pos.name }}</a>
      {% endfor %}
    </div>
  </div>
</div>

<!-- POSITION SECTIONS -->
{% for pos in positions %}
<section class="position-section{% if loop.index is even %} section-alt{% endif %}" id="{{ pos.id }}">
  <div class="container">
    <div class="position-header">
      <div class="position-big-icon" style="{{ pos.icon_style }}"><i class="{{ pos.icon }}"></i></div>
      <div class="position-header-text">
        <h2>{{ pos.name }}</h2>
        <span class="position-term-badge"><i class="fa-solid fa-calendar"></i> {{ pos.term }}</span>
      </div>
    </div>
    <div class="position-body">
      <div class="position-description">
        <p>{{ pos.desc1 | safe }}</p>
        <p>{{ pos.desc2 | safe }}</p>
        <p>{{ pos.desc3 | safe }}</p>
      </div>
      <div class="responsibilities-card">
        <h4><i class="fa-solid fa-list-check"></i> Responsibilities</h4>
        {% for resp in pos.responsibilities %}
        <div class="responsibility-item">{{ resp.item }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% endfor %}

<!-- COMPARISON TABLE -->
<section class="section section-alt">
  <div class="container">
    <span class="tag">{{ comparison.tag }}</span>
    <h2 class="section-title">{{ comparison.heading }}</h2>
    <p class="section-sub">{{ comparison.sub }}</p>
    <table class="comparison-table">
      <thead>
        <tr>
          <th>Position</th>
          <th>Term</th>
          <th>Central Committee</th>
          <th>State Convention</th>
          <th>County Convention</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Precinct Chair</td><td>2 Years</td>
          <td class="yes">✓ Attends</td><td class="no">—</td><td class="no">—</td>
        </tr>
        <tr>
          <td>Precinct Vice-Chair</td><td>2 Years</td>
          <td class="yes">✓ Attends</td><td class="no">—</td><td class="no">—</td>
        </tr>
        <tr>
          <td>State Delegate</td><td>Convention Cycle</td>
          <td class="no">—</td><td class="yes">✓ Votes</td><td class="no">—</td>
        </tr>
        <tr>
          <td>County Delegate</td><td>Convention Cycle</td>
          <td class="no">—</td><td class="no">—</td><td class="yes">✓ Votes</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<!-- CTA -->
<section class="cta-strip">
  <div class="container">
    <h2>{{ cta_strip.heading }}</h2>
    <p>{{ cta_strip.body }}</p>
    <div>
      <a href="{{ cta_strip.btn1_url }}" class="btn-primary"><i class="{{ cta_strip.btn1_icon }}"></i> {{ cta_strip.btn1_text }}</a>
      <a href="{{ cta_strip.btn2_url }}" class="btn-secondary-light"><i class="{{ cta_strip.btn2_icon }}"></i> {{ cta_strip.btn2_text }}</a>
    </div>
  </div>
</section>

{% include "partials/footer.njk" %}

<script>
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
  });
  function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('open'); }
</script>
</body>
</html>
