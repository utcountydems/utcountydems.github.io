<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ header_h1 }} – {{ nav_title or 'CaucusConnect' }} – Utah County Democratic Party</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="/assets/global.css" />
  <style>
    :root {
      --navy:#0d2854; --blue:#1a3d6e; --sky:#38b6ff; --accent:#ffde59;
      --accent2:#ff914d; --white:#fff; --offwhite:#F5F7FA; --text:#444443; --muted:#6b6b6a; --border:#cce8ff;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--offwhite); }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }

    /* ── NAV ── */
    nav#navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 2px solid var(--border); transition: box-shadow .3s; }
    nav#navbar.scrolled { box-shadow: 0 4px 24px rgba(13,40,84,.12); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 82px; }
    .nav-logo { display: flex; align-items: center; gap: 18px; text-decoration: none; flex-shrink: 0; margin-right: 140px; }
    .nav-logo-img { height: 56px; width: auto; display: block; object-fit: contain; }
    .nav-logo-text { display: flex; flex-direction: column; line-height: 1.1; }
    .nav-logo-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: #0d2854; white-space: nowrap; }
    .nav-logo-sub { font-size: .8rem; font-weight: 600; color: var(--muted); white-space: nowrap; letter-spacing: .03em; }
    .nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; }
    .nav-links > li { position: relative; }
    .nav-links > li > a { display: flex; align-items: center; gap: 5px; padding: 8px 14px; color: #0d2854; text-decoration: none; font-size: 1rem; font-weight: 600; border-radius: 6px; transition: background .2s, color .2s; white-space: nowrap; }
    .nav-links > li > a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-links > li.has-dropdown > a::after { content: ''; display: inline-block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; margin-left: 2px; transition: transform .2s; }
    .nav-links > li.has-dropdown:hover > a::after { transform: rotate(180deg); }
    .nav-dropdown { display: none; position: absolute; top: 100%; left: 0; min-width: 200px; background: #fff; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 8px 32px rgba(13,40,84,.12); padding: 8px 6px 6px; z-index: 1001; }
    .nav-links > li.has-dropdown:hover .nav-dropdown { display: block; }
    .nav-dropdown a { display: block; padding: 9px 14px; color: #0d2854; font-size: .95rem; font-weight: 600; text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
    .nav-dropdown a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-cta { background: #38b6ff !important; color: #fff !important; padding: 11px 24px !important; border-radius: 8px !important; font-weight: 700 !important; margin-left: 8px; }
    .nav-cta:hover { background: #1ca8f5 !important; }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
    .nav-hamburger span { display: block; width: 22px; height: 2px; background: #0d2854; border-radius: 2px; transition: .3s; }
    .mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(13,40,84,.98); flex-direction: column; align-items: center; justify-content: center; gap: 24px; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { color: #fff; font-size: 1.4rem; font-weight: 700; text-decoration: none; font-family: 'Playfair Display', serif; }
    @media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }

    /* COMPACT PAGE HEADER BAR — sits flush under nav */
    .page-header {
      background: linear-gradient(90deg, var(--navy), #071229);
      margin-top: 82px; padding: 10px 0;
      border-bottom: 2px solid var(--sky);
    }
    .page-header-inner {
      display: flex; align-items: center; gap: 12px;
    }
    .page-header .tag {
      display: inline-block; font-size: 10px; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--accent); background: rgba(255,222,89,.12);
      border: 1px solid rgba(255,222,89,.3);
      padding: 3px 10px; border-radius: 100px; white-space: nowrap;
    }
    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; font-weight: 700; color: #fff; margin: 0;
    }
    .page-header p { display: none; } /* hidden — space is precious */

    /* MAIN LAYOUT — fills exactly the remaining viewport height */
    .locator-layout {
      display: grid; grid-template-columns: 340px 1fr; gap: 0;
      height: calc(100vh - 68px - 42px); /* viewport minus nav minus header bar */
    }

    /* SIDEBAR */
    .sidebar {
      background: var(--white); border-right: 1px solid var(--border);
      padding: 14px; overflow-y: auto;
      height: 100%;
    }
    .search-box { margin-bottom: 10px; }
    .search-box label { display: block; font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
    .addr-field {
      width: 100%; padding: 10px 14px;
      border: 2px solid var(--border); border-radius: 10px;
      font-size: .95rem; font-family: inherit; outline: none;
      transition: border-color .2s; margin-bottom: 7px; box-sizing: border-box;
    }
    .addr-field:focus { border-color: var(--sky); }
    .addr-city-field { margin-bottom: 7px; }
    .btn-find-precinct {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; padding: 10px; margin-bottom: 7px;
      background: var(--blue); border: none; border-radius: 10px;
      color: #fff; font-size: .95rem; font-weight: 700; cursor: pointer; font-family: inherit;
      transition: background .2s;
    }
    .btn-find-precinct:hover { background: var(--navy); }
    .btn-geo {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; padding: 8px; margin-top: 7px;
      background: none; border: 1px dashed var(--border); border-radius: 8px;
      color: var(--blue); font-size: .9rem; font-weight: 600; cursor: pointer; font-family: inherit;
      transition: background .2s, border-color .2s;
    }
    .btn-geo:hover { background: var(--offwhite); border-color: var(--sky); }

    .result-card {
      border: 2px solid var(--sky); border-radius: 14px; padding: 14px; margin-top: 6px;
      background: linear-gradient(135deg, rgba(56,182,255,.05), rgba(13,40,84,.03));
      display: none;
    }
    .result-card.visible { display: block; }
    .result-precinct { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--navy); margin-bottom: 2px; }
    .result-district { font-size: .85rem; color: var(--muted); margin-bottom: 10px; }
    .result-row { display: flex; gap: 10px; align-items: flex-start; margin-bottom: 8px; }
    .result-row i { color: var(--sky); width: 18px; flex-shrink: 0; margin-top: 2px; }
    .result-row div { font-size: .9rem; line-height: 1.5; color: var(--text); }
    .result-row .label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--muted); margin-bottom: 1px; }
    .result-cta { display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%; padding: 13px 11px; margin-top: 6px; background: var(--navy); color: #fff; border: none; border-radius: 8px; font-weight: 700; font-size: 1rem; cursor: pointer; text-decoration: none; font-family: inherit; transition: background .2s; }
    .result-cta:hover { background: var(--blue); }
    .result-cta-reg { background: #16a34a; font-size: 1rem; padding: 13px 11px; }
    .result-cta-reg:hover { background: #15803d; }
    .result-cta-soon { background: #f1f5f9; color: var(--muted); cursor: default; border: 1px dashed #cbd5e1; }
    .result-cta-soon:hover { background: #f1f5f9; }
    .result-cta-vol { background: #1a6b3a; font-size: 1rem; padding: 13px 11px; }
    .result-cta-vol:hover { background: #155c30; }
    .result-action-link { display: inline-flex; align-items: center; gap: 5px; padding: 4px 11px; border: 1.5px solid var(--blue); color: var(--blue); border-radius: 20px; font-size: .78rem; font-weight: 700; text-decoration: none; background: #fff; transition: background .15s, color .15s; cursor: pointer; }
    .result-action-link:hover { background: var(--blue); color: #fff; }

    .status-msg { padding: 14px; border-radius: 10px; font-size: .9rem; margin-top: 8px; }
    .status-msg.loading { background: rgba(56,182,255,.1); color: var(--blue); }
    .status-msg.error { background: rgba(220,50,50,.08); color: #c0392b; }

    .sample-precincts { margin-top: 10px; }
    .sample-precincts h4 { font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .precinct-list-item {
      display: flex; align-items: center; gap: 12px; padding: 12px;
      border: 1px solid var(--border); border-radius: 10px; margin-bottom: 8px;
      cursor: pointer; transition: border-color .2s, background .2s;
    }
    .precinct-list-item:hover { border-color: var(--sky); background: var(--offwhite); }
    .precinct-num { width: 36px; height: 36px; border-radius: 8px; background: var(--navy); color: #fff; display: flex; align-items: center; justify-content: center; font-size: .8rem; font-weight: 700; flex-shrink: 0; }
    .precinct-info .name { font-weight: 700; font-size: .9rem; color: var(--navy); }
    .precinct-info .loc { font-size: .8rem; color: var(--muted); }

    /* MAP — fills full height of layout row */
    #map { width: 100%; height: 100%; }

    /* Boundary loading overlay */
    #mapOverlay {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      display: flex; align-items: center; justify-content: center;
      background: rgba(245,247,250,.7); z-index: 500; pointer-events: none;
      font-size: .9rem; color: var(--blue); font-weight: 600; gap: 8px;
      transition: opacity .4s;
    }
    #mapOverlay.hidden { opacity: 0; pointer-events: none; }

    /* Leaflet popup */
    .popup-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
    .popup-body { font-size: .85rem; color: var(--muted); line-height: 1.5; }
    .popup-body strong { color: var(--text); }

    /* HOUSE DISTRICT TOGGLE */
    .layer-toggle {
      display: flex; align-items: center; gap: 8px;
      margin-top: 8px; padding: 7px 10px;
      background: rgba(13,40,84,.04); border: 1px solid var(--border);
      border-radius: 8px; cursor: pointer; user-select: none;
    }
    .layer-toggle input[type="checkbox"] {
      width: 16px; height: 16px; accent-color: var(--navy);
      flex-shrink: 0; cursor: pointer;
    }
    .layer-toggle-label { font-size: .82rem; font-weight: 600; color: var(--navy); line-height: 1.3; }
    .layer-toggle-label span { display: block; font-size: .72rem; font-weight: 400; color: var(--muted); margin-top: 1px; }

    /* House district label divicons */
    .hd-label {
      display: inline-block;
      background: rgba(13,40,84,.82);
      color: #fff;
      font-size: 10px; font-weight: 700;
      font-family: 'Source Sans 3', sans-serif;
      padding: 2px 6px; border-radius: 4px;
      white-space: nowrap; pointer-events: none;
      border: 1px solid rgba(255,255,255,.25);
      box-shadow: 0 1px 3px rgba(0,0,0,.3);
      overflow: visible; line-height: 1.4;
    }

    /* Zoom-in hint — shown when precincts are hidden at low zoom */
    #zoomHint {
      position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: 7px;
      background: rgba(13,40,84,.82); color: #fff;
      font-size: .8rem; font-weight: 600;
      padding: 7px 14px; border-radius: 100px;
      pointer-events: none; z-index: 500;
      box-shadow: 0 2px 10px rgba(0,0,0,.25);
      white-space: nowrap;
    }

    /* Satellite toggle button */
    #satelliteToggle {
      position: absolute; top: 10px; right: 10px; z-index: 500;
      background: #fff; border: 2px solid var(--border);
      border-radius: 8px; padding: 6px 12px;
      font-size: .8rem; font-weight: 700; color: var(--navy);
      cursor: pointer; display: flex; align-items: center; gap: 6px;
      box-shadow: 0 2px 8px rgba(0,0,0,.12);
      transition: background .2s, color .2s;
    }
    #satelliteToggle:hover { background: var(--offwhite); }
    #satelliteToggle.active { background: var(--navy); color: #fff; border-color: var(--navy); }

    /* INFO STRIP — collapsed to a slim bar */
    .info-strip { display: none; }

    /* FOOTER */
    footer { background: #070f1f; padding: 20px 0 12px; border-top: 1px solid rgba(255,255,255,.06); }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,.08); margin-bottom: 14px; }
    .footer-brand p { color: rgba(255,255,255,.45); font-size: .85rem; line-height: 1.6; margin-top: 6px; max-width: 280px; }
    .footer-socials { display: flex; gap: 8px; margin-top: 10px; }
    .footer-social { width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,.07); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,.55); font-size: .9rem; text-decoration: none; transition: background .2s, color .2s; }
    .footer-social:hover { background: var(--sky); color: #fff; }
    .footer-col h4 { font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 8px; }
    .footer-col a { display: block; color: rgba(255,255,255,.6); font-size: .85rem; text-decoration: none; margin-bottom: 5px; transition: color .2s; }
    .footer-col a:hover { color: #fff; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; color: rgba(255,255,255,.3); font-size: .82rem; }
    .footer-bottom a { color: rgba(255,255,255,.4); text-decoration: none; }

    @media (max-width: 860px) {
      /* Stack: map on TOP, sidebar below */
      .locator-layout {
        grid-template-columns: 1fr;
        grid-template-rows: 52vh 1fr;
        height: auto;
      }
      /* Map comes first visually */
      .locator-layout > div:first-of-type { order: -1; }
      #map { height: 52vh; min-height: 300px; }

      .sidebar {
        height: auto; max-height: 46vh;
        padding: 16px; border-right: none;
        border-top: 1px solid var(--border);
        overflow-y: auto;
      }

      /* Compact header bar on mobile */
      .page-header h1 { font-size: .95rem; }
      .page-header { padding: 8px 0; }

      /* Tighter inputs */
      .addr-field { padding: 10px 12px; font-size: .95rem; }
      .btn-geo { padding: 11px; font-size: .9rem; }

      /* Result card */
      .result-card { padding: 14px; }
      .result-precinct { font-size: 1rem; }

      /* City shortcuts: 2-up grid on mobile */
      .sample-precincts { margin-top: 16px; }
      .precinct-list-items-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
      .precinct-list-item { margin-bottom: 0; padding: 8px; }
      .precinct-num { width: 28px; height: 28px; font-size: .6rem !important; border-radius: 6px; }
      .precinct-info .name { font-size: .8rem; }
      .precinct-info .loc { font-size: .7rem; }

      /* Footer */
      .footer-inner { grid-template-columns: 1fr; gap: 16px; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }

    @media (max-width: 480px) {
      .locator-layout { grid-template-rows: 48vh 1fr; }
      #map { height: 48vh; min-height: 260px; }
      .sidebar { padding: 12px; max-height: 44vh; }
      .page-header h1 { font-size: .85rem; }
      .precinct-list-items-grid { grid-template-columns: 1fr; }
    }

    /* ── SIDEBAR CANDIDATES PANEL ────────────────────────────────────────── */
    #sidebarCandidates { margin-top: 12px; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(13,40,84,.08); display: none; }
    .scand-header { background: var(--navy); color: #fff; padding: 9px 13px; font-size: .72rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; display: flex; align-items: center; gap: 7px; }
    .scand-header i { color: var(--accent); }
    .scand-group { background: #fff; border-bottom: 1px solid #eef2f8; }
    .scand-group:last-child { border-bottom: none; }
    .scand-group-label { background: #f0f4fa; padding: 6px 12px; font-size: .68rem; font-weight: 700; color: var(--navy); text-transform: uppercase; letter-spacing: .05em; display: flex; align-items: center; gap: 5px; border-bottom: 1px solid #e4eaf5; }
    .scand-group-label i { color: var(--accent2); }
    .scand-card { padding: 10px 12px; border-bottom: 1px solid #f2f4f8; }
    .scand-card:last-child { border-bottom: none; }
    .scand-name { font-size: .88rem; font-weight: 700; color: var(--text); margin-bottom: 3px; }
    .scand-tag { display: inline-block; font-size: .67rem; font-weight: 700; padding: 2px 7px; border-radius: 20px; background: rgba(255,145,77,.15); color: #b04a00; margin-bottom: 4px; letter-spacing: .03em; }
    .scand-tag.both { background: rgba(56,182,255,.15); color: #005f8a; }
    .scand-contact { display: flex; align-items: center; gap: 5px; font-size: .78rem; color: var(--blue); text-decoration: none; margin-top: 2px; word-break: break-all; }
    .scand-contact:hover { text-decoration: underline; }
    .scand-multicounty { font-size: .7rem; color: var(--muted); margin-top: 4px; font-style: italic; display: flex; align-items: center; gap: 4px; }
    .scand-none { padding: 8px 12px; font-size: .8rem; color: var(--muted); font-style: italic; }
  </style>
</head>
<body>

<!-- NAV -->
{% include "partials/nav.njk" %}

<!-- PAGE HEADER — compact bar -->
<div class="page-header">
  <div class="container page-header-inner">
    {% if header_tag %}<span class="tag">{{ header_tag }}</span>{% endif %}
    <h1>{{ header_h1 }}</h1>
  </div>
</div>

<!-- MAIN LAYOUT -->
<div class="locator-layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="search-box">
      <label>{{ search_street_label }}</label>
      <input type="text" id="addrStreet" class="addr-field" placeholder="{{ search_street_placeholder }}" required />
      <input type="text" id="addrCity" class="addr-field addr-city-field" placeholder="{{ search_city_label }}" required />
      <button class="btn-find-precinct" onclick="searchAddress()">
        <i class="fa-solid fa-magnifying-glass"></i> {{ search_btn_text }}
      </button>
      <button class="btn-geo" onclick="geolocate()">
        <i class="fa-solid fa-location-crosshairs"></i> {{ geo_btn_text }}
      </button>
    </div>

    <div class="search-box" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border);">
      <label>Voter ID</label>
      <input type="text" id="vidInput" class="addr-field" placeholder="Enter Voter ID"
             onkeydown="if(event.key==='Enter') searchVoterId()" />
      <button class="btn-find-precinct" onclick="searchVoterId()">
        <i class="fa-solid fa-id-card"></i> Find Voter
      </button>
    </div>

    <div id="statusMsg"></div>
    <div style="margin-bottom:12px;padding:14px 16px;background:rgba(56,182,255,.07);border-radius:10px;border:1px solid rgba(56,182,255,.2);">
      <p style="font-size:.82rem;color:var(--muted);line-height:1.6;margin:0;"><i class="fa-solid fa-circle-info" style="color:var(--sky);margin-right:6px;"></i>Search your address to find your precinct.</p>
    </div>
    <div class="result-card" id="resultCard">
      <div class="result-precinct" id="rPrecinct">Your Precinct</div>
      <div class="result-district" id="rDistrict">Utah County · March 17, 2026</div>
      <div class="result-row" id="rDistrictRow" style="display:none;">
        <i class="fa-solid fa-landmark"></i>
        <div><div class="label">2026 Races</div><div id="rDistrictInfo"></div></div>
      </div>
      <div id="rPartyBreakdown" style="display:none;margin:8px 0;padding:8px 0;border-bottom:1px solid var(--border);"></div>
      <div class="result-row" id="rCandsRow" style="display:none;">
        <i class="fa-solid fa-person"></i>
        <div><a onclick="event.preventDefault(); scrollSidebarToCandidates();" href="#" class="result-action-link"><i class="fa-solid fa-chevron-down"></i> See Your Candidates</a></div>
      </div>
      <div class="result-row" id="rChairRow" style="display:none;">
        <i class="fa-solid fa-person-chalkboard"></i>
        <div><div class="label">Current Chair</div><div id="rChair"></div></div>
      </div>

      <!-- Registration: active link when regUrl is set, "coming soon" state otherwise -->
      <a id="rRegBtn" href="#" target="_blank" class="result-cta" style="display:none;">
        <i class="fa-solid fa-clipboard-list"></i> Register for Your Caucus
      </a>
      <div id="rRegSoon" class="result-cta result-cta-soon" style="display:none;">
        <i class="fa-solid fa-clock"></i> Caucus Registration Opening Soon
      </div>
      <!-- Volunteer: shown only when volUrl is set -->
      <a id="rVolBtn" href="#" target="_blank" class="result-cta result-cta-vol" style="display:none;">
        <i class="fa-solid fa-hand-holding-heart"></i> Volunteer at This Caucus
      </a>
      <div id="rDisclaimer" style="display:none; margin-top:8px; font-size:.75rem; color:var(--muted); text-align:center; line-height:1.4;">
