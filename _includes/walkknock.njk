  // ── Boundary polygon layer ──
  // polygonLayers maps PRECINCTID → Leaflet layer reference for highlight/select
  const polygonLayers = {};
  // precinctRings maps PRECINCTID → { id, city, rings[] } for point-in-polygon testing
  const precinctRings = {};
  // hdRings maps HD number → GeoJSON coordinate rings for HD point-in-polygon lookup in showResult()
  const hdRings = {};
  let selectedLayer = null;
  let userMarker = null;
  // Preserved across the HD backfill so districts + coords survive loadHouseDistricts() re-render
  let lastSearchLat = null;
  let lastSearchLng = null;
  let lastSearchDistricts = null;

  // All precinct polygon layers live in this group so we can show/hide as one unit
  const precinctLayerGroup = L.layerGroup().addTo(map);

  // Voter home markers — loaded per-precinct when a precinct is selected
  const voterLayerGroup = L.layerGroup().addTo(map);
  let currentVoterPrecinctId = null;

  // ── Point-in-polygon (ray-casting algorithm) ──
  // Tests whether [lng, lat] falls inside a single GeoJSON ring (array of [lng, lat] pairs)
  function pointInRing(lng, lat, ring) {
    let inside = false;
    for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
      const xi = ring[i][0], yi = ring[i][1];
      const xj = ring[j][0], yj = ring[j][1];
      if (((yi > lat) !== (yj > lat)) && (lng < (xj - xi) * (lat - yi) / (yj - yi) + xi)) {
        inside = !inside;
      }
    }
    return inside;
  }

  // Tests a point against all loaded precinct polygons.
  // Handles multi-ring polygons: ring[0] = exterior, ring[1+] = holes.
  // Returns { id, city } of the matching precinct, or null if none found.
  function findPrecinctByPoint(lat, lng) {
    for (const [id, entry] of Object.entries(precinctRings)) {
      const rings = entry.rings;
      if (!rings || !rings.length) continue;
      // Must be inside outer ring
      if (!pointInRing(lng, lat, rings[0])) continue;
      // Must NOT be inside any hole rings
      let inHole = false;
      for (let r = 1; r < rings.length; r++) {
        if (pointInRing(lng, lat, rings[r])) { inHole = true; break; }
      }
      if (!inHole) return { id, city: entry.city };
    }
    return null;
  }

  // Queries the precinct FeatureServer for Senate, School Board, Congressional, City Council
  // district numbers at a given lat/lng. Returns an attributes object or null on failure.
  async function fetchDistrictsForPoint(lat, lng) {
    try {
      const params = new URLSearchParams({
        geometry: `${lng},${lat}`,
        geometryType: 'esriGeometryPoint',
        inSR: '4326',
        spatialRel: 'esriSpatialRelIntersects',
        outFields: 'STATESENATE,STATESCHOOLBOARD,CONGRESIONAL',
        returnGeometry: 'false',
        f: 'json'
      });
      const res = await fetch(`${FEATURE_URL}?${params}`);
      const json = await res.json();
      if (json.features && json.features.length > 0) return json.features[0].attributes;
    } catch(e) { console.warn('District lookup failed:', e); }
    return null;
  }

  function findHdForPoint(lat, lng) {
    for (const [distStr, rings] of Object.entries(hdRings)) {
      if (!rings || !rings[0]) continue;
      if (pointInRing(lng, lat, rings[0])) {
        let inHole = false;
        for (let r = 1; r < rings.length; r++) {
          if (pointInRing(lng, lat, rings[r])) { inHole = true; break; }
        }
        if (!inHole) return parseInt(distStr, 10);
      }
    }
    return null;
  }

  // ── Load boundaries from ArcGIS FeatureServer ──
  // Fetches all 525 precincts in batches of 100, converts Esri JSON → GeoJSON, adds to map
  const FEATURE_URL = 'https://services1.arcgis.com/9DapJHuwsEakbYuW/arcgis/rest/services/Utah_County_-_Current_Precincts/FeatureServer/4/query';

  function esriRingsToGeoJSON(rings) {
    // Esri polygon rings → GeoJSON Polygon (handles holes: first ring = exterior, rest = holes)
    return { type: 'Polygon', coordinates: rings };
  }

  async function fetchBatch(offset) {
    const params = new URLSearchParams({
      where: '1=1',
      outFields: 'PRECINCTID,CITY',
      geometryPrecision: 4,
      outSR: 4326,
      returnGeometry: true,
      f: 'json',
      resultRecordCount: 100,
      resultOffset: offset
    });
    const res = await fetch(`${FEATURE_URL}?${params}`);
    const json = await res.json();
    return json.features || [];
  }

  async function loadBoundaries() {
    setStatus('<i class="fa-solid fa-spinner fa-spin"></i> Loading precinct boundaries…');
    try {
      // 525 precincts inside county + 6 edge precincts = 531 total fetched in 6 batches of 100
      const offsets = [0, 100, 200, 300, 400, 500];
      const batches = await Promise.all(offsets.map(fetchBatch));
      const allFeatures = batches.flat();

      allFeatures.forEach(f => {
        const id   = f.attributes.PRECINCTID;
        const city = f.attributes.CITY || 'Utah County';
        const geom = f.geometry;
        if (!geom || !geom.rings) return;

        const geojson = {
          type: 'Feature',
          properties: { id, city },
          geometry: esriRingsToGeoJSON(geom.rings)
        };

        // Determine if this precinct's centroid is inside the county polygon
        // Precincts outside get no fill; precincts inside get the light blue fill
        let insideCounty = true;
        if (countyRing && geom.rings && geom.rings[0] && geom.rings[0].length) {
          // Use the first vertex of the precinct ring as a quick centroid proxy
          const testPt = geom.rings[0][0];
          insideCounty = pointInRing(testPt[0], testPt[1], countyRing);
        }
        const baseStyle = insideCounty ? STYLE_DEFAULT : STYLE_DEFAULT_NOFILL;

        const layer = L.geoJSON(geojson, {
          style: baseStyle,
          onEachFeature: (feature, lyr) => {
            lyr.on({
              mouseover(e) {
                if (lyr !== selectedLayer) lyr.setStyle(STYLE_HOVER);
              },
              mouseout(e) {
                if (lyr !== selectedLayer) lyr.setStyle(baseStyle);
              },
              async click(e) {
                highlightLayer(lyr, id, city);
                const p = precincts.find(x => x.id === id);
                const clat = p ? p.lat : e.latlng.lat;
                const clng = p ? p.lng : e.latlng.lng;
                showResult(id, city, clat, clng, null);
                L.DomEvent.stopPropagation(e);
                const districts = await fetchDistrictsForPoint(clat, clng);
                lastSearchLat = clat; lastSearchLng = clng; lastSearchDistricts = districts;
                showResult(id, city, clat, clng, districts);
              }
            });
          }
        }).addTo(precinctLayerGroup);

        polygonLayers[id] = layer;
        // Also store rings for point-in-polygon testing
        precinctRings[id] = { id, city, rings: geom.rings };
      });

      // Hide map loading overlay
      const overlay = document.getElementById('mapOverlay');
      if (overlay) overlay.classList.add('hidden');
      setTimeout(() => { if (overlay) overlay.remove(); }, 500);

      document.getElementById('statusMsg').innerHTML = '';
    } catch(err) {
      setStatus('Could not load precinct boundaries. Check your connection and refresh.', 'error');
      const overlay = document.getElementById('mapOverlay');
      if (overlay) overlay.remove();
      console.error('Boundary load error:', err);
    }
  }

  function highlightLayer(layer, id, city) {
    // Reset previous selection
    if (selectedLayer) selectedLayer.setStyle(STYLE_DEFAULT);
    layer.setStyle(STYLE_SELECTED);
    selectedLayer = layer;
  }

  async function selectPrecinct(lat, lng, id, name, city) {
    map.flyTo([lat, lng], 13, { duration: 1.2 });
    showResult(id, city || name, lat, lng, null);   // immediate sidebar feedback
    // Fetch districts and wait for fly animation together — popup opens with full data
    const [districts] = await Promise.all([
      fetchDistrictsForPoint(lat, lng),
      new Promise(resolve => setTimeout(resolve, 1300))
    ]);
    lastSearchLat = lat; lastSearchLng = lng; lastSearchDistricts = districts;
    showResult(id, city || name, lat, lng, districts);
    const lyr = polygonLayers[id];
    if (lyr) {
      highlightLayer(lyr, id, city || name);
    }
  }

  function showResult(id, city, pointLat, pointLng, districts) {
    // Find the precinct object for city info
    const p = precincts.find(x => x.id === id);
    const cityLabel = (p && p.city) ? p.city : (city || id);
    document.getElementById('rPrecinct').textContent = `Precinct ${id} — ${cityLabel}`;

    // Look up HD for district row display
    const lookupLat = (pointLat != null) ? pointLat : (p ? p.lat : null);
    const lookupLng = (pointLng != null) ? pointLng : (p ? p.lng : null);
    let hdNum = null;
    if (lookupLat != null && Object.keys(hdRings).length > 0) {
      hdNum = findHdForPoint(lookupLat, lookupLng);
    }

    document.getElementById('rDistrict').textContent = hdNum ? `House District ${hdNum}` : '';
    document.getElementById('resultCard').classList.add('visible');
    document.getElementById('statusMsg').innerHTML = '';
    const disc = document.getElementById('rDisclaimer');
    if (disc) disc.style.display = 'block';

    // Reset party breakdown — will be populated by loadVoterMarkers
    const breakdown = document.getElementById('rPartyBreakdown');
    if (breakdown) breakdown.style.display = 'none';

    // Registration + Volunteer buttons — hidden for canvass
    const regBtn  = document.getElementById('rRegBtn');
    const regSoon = document.getElementById('rRegSoon');
    const volBtn  = document.getElementById('rVolBtn');
    if (regBtn) regBtn.style.display = 'none';
    if (regSoon) regSoon.style.display = 'none';
    if (volBtn) volBtn.style.display = 'none';

    // Populate district row — HD from hdRings lookup, others from fetchDistrictsForPoint
    const distRow = document.getElementById('rDistrictRow');
    const distInfo = document.getElementById('rDistrictInfo');
    if (distRow && distInfo) {
      const parts = [];
      if (hdNum)                        parts.push(`House District ${hdNum}`);
      if (districts && districts.STATESENATE && SD_UP_2026.has(String(districts.STATESENATE)))
                                        parts.push(`Senate District ${districts.STATESENATE}`);
      parts.push('County Commissioner — Seat A');
      parts.push('County Commissioner — Seat B');
      if (districts && districts.STATESCHOOLBOARD && SSB_UP_2026.has(String(districts.STATESCHOOLBOARD)))
                                        parts.push(`State School Board District ${districts.STATESCHOOLBOARD}`);
      if (districts && districts.CONGRESIONAL)     parts.push(`Congressional District ${districts.CONGRESIONAL}`);
      distInfo.innerHTML = parts.join('<br>');
      distRow.style.display = 'flex';
    } else if (distRow) {
      distRow.style.display = 'none';
    }

    // Show matching Democratic candidates below the map
    const sdNum   = districts && districts.STATESENATE      ? String(districts.STATESENATE)      : null;
    const ssbNum  = districts && districts.STATESCHOOLBOARD ? String(districts.STATESCHOOLBOARD)  : null;
    const congNum = districts && districts.CONGRESIONAL     ? String(districts.CONGRESIONAL)      : null;
    loadVoterMarkers(id);
    showCandidates(hdNum, sdNum, ssbNum, congNum, id);
  }

  // ── Voter home markers ────────────────────────────────────────────────────
  // Per-precinct JSON files live at /assets/voters/{precinctId}.json
  // Generated by scripts/geocode_voters.py from the voter registration CSV.

  function voterPartyColor(party) {
    const p = (party || '').toLowerCase();
    if (p === 'dem' || p === 'democratic') return '#1a3d6e';
    if (p === 'rep' || p === 'republican') return '#cc2200';
    return '#888888';
  }

  function voterPartyLabel(party) {
    const p = (party || '').toLowerCase();
    if (p === 'dem' || p === 'democratic') return 'Democrat';
    if (p === 'rep' || p === 'republican') return 'Republican';
    if (p === 'none' || p === 'uaf' || p === 'unaffiliated') return 'Unaffiliated';
    return party || 'Unknown';
  }

  // ── Metric color scale: deep red → yellow → deep blue ────────────────────
  // t = 0.0 (lowest) → 1.0 (highest)
  function metricColor(t) {
    t = Math.max(0, Math.min(1, t));
    let r, g, b;
    if (t <= 0.5) {
      const s = t * 2;
      r = Math.round(204 + (255 - 204) * s);  // #cc0000 → #ffdd00
      g = Math.round(0   + (221 - 0)   * s);
      b = 0;
    } else {
      const s = (t - 0.5) * 2;
      r = Math.round(255 + (13  - 255) * s);  // #ffdd00 → #0d2854
      g = Math.round(221 + (40  - 221) * s);
      b = Math.round(0   + (84  - 0)   * s);
    }
    const lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
    return { bg: `rgb(${r},${g},${b})`, fg: lum > 0.52 ? '#222' : '#fff' };
  }

  // ── Deterministic mock normal values seeded from voter id ─────────────────
  function _h(s) {
    let h = 0;
    for (let i = 0; i < s.length; i++) h = (Math.imul(h, 31) + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }
  function mockNormal(id, salt, mean = 50, sd = 16) {
    let sum = 0;
    for (let i = 0; i < 6; i++) sum += (_h(String(id) + salt + i) % 10000) / 10000;
    return Math.max(1, Math.min(100, Math.round(mean + (sum / 6 - 0.5) * sd * 7.1)));
  }

  // Render a single metric row: label + color-coded badge
  function metricBadge(label, value, t) {
    const { bg, fg } = metricColor(t);
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:2px 0;">
      <span style="font-size:.72rem;color:#666;">${label}</span>
      <span style="background:${bg};color:${fg};padding:1px 8px;border-radius:4px;font-size:.78rem;font-weight:800;min-width:36px;text-align:center;">${value}</span>
    </div>`;
  }

  // Build metric block for one voter
  function voterMetrics(v) {
    const uid = String(v.vid || v.name || '');
    const engVal  = v.v_score ? parseFloat(v.v_score).toFixed(1) : null;
    const engT    = v.decile  ? (parseInt(v.decile) - 1) / 9 : 0.5;
    const donVal  = mockNormal(uid, 'don');
    const volVal  = mockNormal(uid, 'vol');
    return (engVal ? metricBadge('Engagement', engVal, engT) : '') +
           metricBadge('Donations', donVal, donVal / 100) +
           metricBadge('Volunteerism', volVal, volVal / 100);
  }

  // Household popup — one card showing all voters at the same parcel centroid
  function buildHouseholdPopupHtml(residents) {
    const addr = residents[0].address || '';
    const rows = residents.map(v => {
      const pColor = voterPartyColor(v.party);
      const label  = voterPartyLabel(v.party);
      return `
        <div style="padding:7px 0;border-bottom:1px solid #eef2f7;">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:5px;">
            <div style="font-weight:700;font-size:.87rem;color:#0d2854;flex:1;">${v.name || 'Resident'}</div>
            <span style="display:inline-block;padding:1px 7px;border-radius:100px;font-size:.68rem;font-weight:700;background:${pColor};color:#fff;">${label}</span>
          </div>
          ${voterMetrics(v)}
        </div>`;
    }).join('');
    return `
      <div style="min-width:230px;max-width:300px;">
        <div style="font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#38b6ff;margin-bottom:3px;">
          <i class="fa-solid fa-house" style="margin-right:4px;"></i>Household
        </div>
        <div style="font-size:.8rem;color:#555;margin-bottom:6px;">${addr}</div>
        ${rows}
        <div style="padding-top:5px;font-size:.65rem;color:#aaa;text-align:right;">${residents.length} registered voter${residents.length !== 1 ? 's' : ''}</div>
      </div>`;
  }

  // Find all voters at the nearest parcel centroid to a given lat/lng
  function findHouseholdNearPoint(voters, lat, lng, threshDeg = 0.0012) {
    let minDist = Infinity, nearest = null;
    voters.forEach(v => {
      if (v.lat == null || v.lng == null) return;
      const d = Math.sqrt(Math.pow(v.lat - lat, 2) + Math.pow(v.lng - lng, 2));
      if (d < minDist) { minDist = d; nearest = v; }
    });
    if (!nearest || minDist > threshDeg) return [];
    return voters.filter(v => v.lat === nearest.lat && v.lng === nearest.lng);
  }

  function buildVoterPopupHtml(v) {
    const pColor = voterPartyColor(v.party);
    const label  = voterPartyLabel(v.party);
    return `
      <div class="popup-title" style="font-size:.95rem;">${v.name || 'Voter'}</div>
      <div class="popup-body">
        <span style="display:inline-block;padding:2px 9px;border-radius:100px;font-size:.72rem;font-weight:700;background:${pColor};color:#fff;margin-bottom:7px;">${label}</span><br>
        <i class="fa-solid fa-location-dot" style="color:#38b6ff;margin-right:5px;"></i>${v.address || ''}<br>
        <i class="fa-solid fa-map" style="color:#38b6ff;margin-right:5px;"></i>Precinct ${v.precinct}${v.hd ? ' &middot; HD&nbsp;' + v.hd : ''}
        <div style="margin-top:7px;">${voterMetrics(v)}</div>
      </div>`;
  }

  async function loadVoterMarkers(precinctId) {
    voterLayerGroup.clearLayers();
    currentVoterPrecinctId = precinctId;
    if (!precinctId) return;
    try {
      const resp = await fetch(`/assets/voters/${precinctId}.json`);
      if (!resp.ok) return;
      const voters = await resp.json();
      showPartyBreakdown(voters);
      voters.forEach(v => {
        if (v.lat == null || v.lng == null) return;
        const color = voterPartyColor(v.party);
        L.circleMarker([v.lat, v.lng], {
          radius: 5,
          color: '#fff',
          weight: 1.5,
          fillColor: color,
          fillOpacity: 0.9,
          zIndexOffset: 500
        })
          .bindPopup(buildVoterPopupHtml(v), { maxWidth: 300 })
          .addTo(voterLayerGroup);
      });
    } catch (_) {
      // Voter data unavailable — fail silently
    }
  }

  function showPartyBreakdown(voters) {
    const el = document.getElementById('rPartyBreakdown');
    if (!el || !voters.length) return;
    const total = voters.length;
    const dem = voters.filter(v => v.party === 'Dem').length;
    const rep = voters.filter(v => v.party === 'Rep').length;
    const una = total - dem - rep;
    const pct = n => Math.round(n / total * 100);
    const bar = (label, count, color) => {
      const p = pct(count);
      return `<div style="display:flex;align-items:center;gap:7px;margin-bottom:5px;">
        <span style="font-size:.72rem;color:#555;width:88px;flex-shrink:0;">${label}</span>
        <div style="flex:1;background:#eef2f7;border-radius:4px;height:8px;overflow:hidden;">
          <div style="width:${p}%;height:100%;background:${color};border-radius:4px;transition:width .4s;"></div>
        </div>
        <span style="font-size:.72rem;font-weight:700;color:#444;width:34px;text-align:right;">${p}%</span>
      </div>`;
    };
    el.innerHTML =
      bar('Democrat',    dem, '#1d4ed8') +
      bar('Republican',  rep, '#dc2626') +
      bar('Unaffiliated', una, '#94a3b8');
    el.style.display = 'block';
  }

  // Builds the map popup HTML for a precinct, with the correct HD caucus venue if boundaries are loaded
  function openSidebarFromPopup() {
    map.closePopup();
    const sidebar = document.querySelector('.sidebar');
    const card    = document.getElementById('resultCard');
    if (!sidebar || !card) return;
    // On mobile the sidebar is above the map — scroll it into view first
    sidebar.scrollIntoView({ behavior: 'smooth', block: 'start' });
    // Then scroll within the sidebar so the result card is at the top
    setTimeout(() => {
      const sTop = sidebar.getBoundingClientRect().top;
      const cTop = card.getBoundingClientRect().top;
      sidebar.scrollTo({ top: sidebar.scrollTop + (cTop - sTop) - 8, behavior: 'smooth' });
    }, 350);
  }

  function buildPrecinctPopupHtml(id, city, title, pointLat, pointLng, districts) {
    const displayTitle = title || `Precinct ${id}`;
    return `
      <div class="popup-title">${displayTitle}</div>
      <div class="popup-body">
        <strong>${city}</strong><br/>
        <span style="color:#888;font-size:.82rem;">No Voter Record Available</span>
      </div>
    `;
  }

  function setStatus(msg, type = 'loading') {
    document.getElementById('statusMsg').innerHTML = `<div class="status-msg ${type}">${msg}</div>`;
  }

  // ── Geocoding: US Census (primary) + Nominatim (fallback) ──
  // Census geocoder natively handles Utah cardinal-direction addresses (e.g. "185 E 400 N")
  // No API key needed — free US government service

  // Expand Utah-style cardinal directions for Nominatim fallback
  // e.g. "185 E 400 N" → "185 East 400 North"  (Nominatim understands spelled-out cardinals)
  function expandCardinals(str) {
    return str
      .replace(/\bN\b/g, 'North')
      .replace(/\bS\b/g, 'South')
      .replace(/\bE\b/g, 'East')
      .replace(/\bW\b/g, 'West');
  }

  // JSONP helper — injects a <script> tag so Census geocoder works from file:// (no CORS issues)
  function censusGeocodeJsonp(url) {
    return new Promise((resolve, reject) => {
      const cbName = '__censusGeo_' + Date.now();
      const script = document.createElement('script');
      const timer = setTimeout(() => {
        cleanup();
        reject(new Error('Census JSONP timeout'));
      }, 8000);
      function cleanup() {
        clearTimeout(timer);
        delete window[cbName];
        if (script.parentNode) script.parentNode.removeChild(script);
      }
      window[cbName] = function(data) { cleanup(); resolve(data); };
      script.src = url + '&callback=' + cbName;
      script.onerror = () => { cleanup(); reject(new Error('Census JSONP script error')); };
      document.head.appendChild(script);
    });
  }

  // ── Voter ID search ──────────────────────────────────────────────────────
  let _vidIndex = null;
  async function _getVidIndex() {
    if (_vidIndex) return _vidIndex;
    const resp = await fetch('/assets/voters/vid_index.json');
    if (!resp.ok) throw new Error('Could not load voter index');
    _vidIndex = await resp.json();
    return _vidIndex;
  }

  async function searchVoterId() {
    const vid = document.getElementById('vidInput').value.trim();
    if (!vid) { setStatus('Please enter a Voter ID.', 'error'); return; }
    setStatus('<i class="fa-solid fa-spinner fa-spin"></i> Searching…');
    try {
      const index = await _getVidIndex();
      const precinctId = index[vid];
      if (!precinctId) { setStatus('Voter ID not found.', 'error'); return; }

      const vResp = await fetch(`/assets/voters/${precinctId}.json`);
      if (!vResp.ok) throw new Error('Could not load precinct data');
      const voters = await vResp.json();
      const voter = voters.find(v => String(v.vid) === vid);
      if (!voter) { setStatus('Voter record not found.', 'error'); return; }

      const lat = voter.lat;
      const lng = voter.lng;
      const precinctInfo = precincts.find(p => p.id === precinctId);
      const city = precinctInfo ? precinctInfo.city : '';

      if (!lat || !lng) {
        // No coordinates — just highlight the precinct
        if (precinctInfo) {
          showResult(precinctId, city, precinctInfo.lat, precinctInfo.lng, null);
          map.flyTo([precinctInfo.lat, precinctInfo.lng], 13, { duration: 1.2 });
          const lyr = polygonLayers[precinctId];
          if (lyr) highlightLayer(lyr, precinctId, city);
        }
        setStatus('Voter found in precinct ' + precinctId + ', but no location data available.', 'error');
        return;
      }

      if (userMarker) map.removeLayer(userMarker);
      userMarker = L.marker([lat, lng], { icon: makeIcon('#ff914d'), zIndexOffset: 1000 })
        .addTo(map)
        .bindPopup(buildVoterPopupHtml(voter), { maxWidth: 300 })
        .openPopup();
      map.flyTo([lat, lng], 17, { duration: 1.2 });

      const districts = await fetchDistrictsForPoint(lat, lng);
      lastSearchLat = lat; lastSearchLng = lng; lastSearchDistricts = districts;
      showResult(precinctId, city, lat, lng, districts);
      const lyr = polygonLayers[precinctId];
      if (lyr) highlightLayer(lyr, precinctId, city);
      await loadVoterMarkers(precinctId);
      document.getElementById('statusMsg').innerHTML = '';
    } catch(e) {
      setStatus('Error searching for voter. Please try again.', 'error');
      console.error(e);
    }
  }

  async function searchAddress() {
    const street = document.getElementById('addrStreet').value.trim();
    const city   = document.getElementById('addrCity').value.trim();
    if (!street) { setStatus('Please enter a street address.', 'error'); return; }
    if (!city)   { setStatus('Please enter a city.', 'error'); return; }
    setStatus('<i class="fa-solid fa-spinner fa-spin"></i> Searching…');

    // Build display label for popup and status messages
    const addr = [street, city, 'UT'].filter(Boolean).join(', ');

    let latF, lngF;

    // ── 1. Try US Census structured geocoder via JSONP ──
    // Census handles all Utah grid address formats — both NS-first (e.g. "410 S 300 E")
    // and EW-first (e.g. "185 E 400 N") — correctly, including N/S disambiguation.
    // Very high-number addresses (e.g. "2925 N 3550 W") may not be found; Nominatim
    // serves as fallback in that case.
    try {
      const censusParams = new URLSearchParams({
        street: street,
        city:   city || 'Utah County',
        state:  'UT',
        benchmark: 'Public_AR_Current',
        format: 'jsonp'
      });
      const censusUrl = `https://geocoding.geo.census.gov/geocoder/locations/address?` + censusParams;
      const censusData = await censusGeocodeJsonp(censusUrl);
      const matches = censusData.result && censusData.result.addressMatches;
      if (matches && matches.length > 0) {
        const coords = matches[0].coordinates;
        // Sanity-check: reject Census results outside Utah County bounds.
        const inUtahCounty = coords.y >= 39.82 && coords.y <= 40.66 &&
                             coords.x >= -112.25 && coords.x <= -111.42;
        if (inUtahCounty) {
          latF = coords.y;
          lngF = coords.x;
          console.log('Census geocoder success:', latF, lngF, matches[0].matchedAddress);
        } else {
          console.log('Census result outside Utah County bounds — falling back to Nominatim:', coords.y, coords.x);
        }
      } else {
        console.log('Census geocoder: no matches found for:', street, city);
      }
    } catch(e) { console.warn('Census geocoder failed (will try Nominatim):', e.message || e); }

    // ── 2. Fall back to Nominatim with structured params ──
    if (!latF) {
      try {
        // Expand abbreviated cardinals so Nominatim can parse the street name.
        // For NS-first addresses (e.g. "410 S 300 E"), only expand EW (the street-name
        // part) and leave the NS directional abbreviated ("S"/"N") so Nominatim parses
        // "410 S" as the compound house number rather than reading "South 300 East" as
        // the street name (which previously caused it to find "300 South" instead).
        const isNSFirst = /^\d+\s+[NS]\b/i.test(street);
        let nomStreet;
        if (isNSFirst) {
          nomStreet = street.replace(/\bE\b/g, 'East').replace(/\bW\b/g, 'West');
        } else {
          nomStreet = expandCardinals(street);
        }
        const nomCity   = city || 'Utah County';
        console.log('Falling back to Nominatim:', nomStreet, '|', nomCity);
        // Use structured params (street/city/state) — no comma-parsing needed
        const nomUrl = `https://nominatim.openstreetmap.org/search?format=json` +
          `&street=${encodeURIComponent(nomStreet)}` +
          `&city=${encodeURIComponent(nomCity)}` +
          `&state=Utah&country=USA&limit=1`;
        const nomRes  = await fetch(nomUrl, { headers: { 'Accept-Language': 'en' } });
        const nomData = await nomRes.json();
        if (!nomData.length) { setStatus('Address not found. Try a more specific address.', 'error'); return; }
        latF = parseFloat(nomData[0].lat);
        lngF = parseFloat(nomData[0].lon);
        console.log('Nominatim fallback result:', latF, lngF);
      } catch(e) { setStatus('Could not reach geocoding service. Try again.', 'error'); return; }
    }

    // ── Place pin — show user's original address in popup ──
    if (userMarker) map.removeLayer(userMarker);
    userMarker = L.marker([latF, lngF], { icon: makeIcon('#ff914d'), zIndexOffset: 1000 })
      .addTo(map)
      .bindPopup(`<div class="popup-title" style="font-size:.9rem;">${addr}</div><div class="popup-body" style="color:#888;font-size:.8rem;">Loading household…</div>`)
      .openPopup();

    map.flyTo([latF, lngF], 14, { duration: 1.2 });

    // ── Point-in-polygon match (exact) ──
    // Falls back to nearest-centroid only if boundary data hasn't loaded yet
    async function resolveAddressMatch() {
      let match = null;

      if (Object.keys(precinctRings).length > 0) {
        match = findPrecinctByPoint(latF, lngF);
      } else {
        const MAX_DIST = 0.07;
        let minDist = Infinity;
        precincts.forEach(p => {
          const d = Math.sqrt(Math.pow(latF - p.lat, 2) + Math.pow(lngF - p.lng, 2));
          if (d < minDist) { minDist = d; match = p; }
        });
        if (minDist > MAX_DIST) match = null;
      }

      if (match) {
        const districts = await fetchDistrictsForPoint(latF, lngF);
        lastSearchLat = latF; lastSearchLng = lngF; lastSearchDistricts = districts;
        showResult(match.id, match.city, latF, lngF, districts);
        const lyr = polygonLayers[match.id];
        if (lyr) highlightLayer(lyr, match.id, match.city);
        document.getElementById('statusMsg').innerHTML = '';

        // Load voter data and show household card on the pin
        try {
          const vResp = await fetch(`/assets/voters/${match.id}.json`);
          if (vResp.ok) {
            const allVoters = await vResp.json();
            const household = findHouseholdNearPoint(allVoters, latF, lngF);
            if (userMarker) {
              userMarker.setPopupContent(
                household.length > 0
                  ? buildHouseholdPopupHtml(household)
                  : buildPrecinctPopupHtml(match.id, match.city, 'Your Address', latF, lngF, districts)
              );
              userMarker.openPopup();
            }
          }
        } catch (_) {
          if (userMarker) {
            userMarker.setPopupContent(buildPrecinctPopupHtml(match.id, match.city, 'Your Address', latF, lngF, districts));
            userMarker.openPopup();
          }
        }
      } else {
        setStatus(
          '<i class="fa-solid fa-circle-info" style="margin-right:6px;"></i>' +
          '<strong>Your address was found</strong>, but it appears to be outside Utah County. ' +
          'To find your official precinct, visit ' +
          '<a href="https://vote.utah.gov" target="_blank" style="color:var(--blue);font-weight:700;">vote.utah.gov</a>.',
          'loading'
        );
      }
    }
    setTimeout(resolveAddressMatch, 1000);
  }

  function geolocate() {
    if (!navigator.geolocation) { setStatus('Geolocation not supported by your browser.', 'error'); return; }
    setStatus('<i class="fa-solid fa-spinner fa-spin"></i> Getting your location…');
    navigator.geolocation.getCurrentPosition(pos => {
      const { latitude: lat, longitude: lng } = pos.coords;
      if (userMarker) map.removeLayer(userMarker);
      userMarker = L.marker([lat, lng], { icon: makeIcon('#ff914d'), zIndexOffset: 1000 })
        .addTo(map).bindPopup('<div class="popup-title">Your Caucus Location</div>').openPopup();
      map.flyTo([lat, lng], 14, { duration: 1.2 });

      // ── Point-in-polygon match (exact) ──
      async function resolveGeoMatch() {
        let match = null;

        if (Object.keys(precinctRings).length > 0) {
          match = findPrecinctByPoint(lat, lng);
        } else {
          const MAX_DIST = 0.07;
          let minDist = Infinity;
          precincts.forEach(p => {
            const d = Math.sqrt(Math.pow(lat - p.lat, 2) + Math.pow(lng - p.lng, 2));
            if (d < minDist) { minDist = d; match = p; }
          });
          if (minDist > MAX_DIST) match = null;
        }

        if (match) {
          const districts = await fetchDistrictsForPoint(lat, lng);
          lastSearchLat = lat; lastSearchLng = lng; lastSearchDistricts = districts;
          showResult(match.id, match.city, lat, lng, districts);
          const lyr = polygonLayers[match.id];
          if (lyr) {
            highlightLayer(lyr, match.id, match.city);
          }
          document.getElementById('statusMsg').innerHTML = '';
        } else {
          setStatus(
            '<i class="fa-solid fa-circle-info" style="margin-right:6px;"></i>' +
            '<strong>Location found</strong>, but it appears to be outside Utah County. ' +
            'To find your official precinct, visit ' +
            '<a href="https://vote.utah.gov" target="_blank" style="color:var(--blue);font-weight:700;">vote.utah.gov</a>.',
            'loading'
          );
        }
      }
      setTimeout(resolveGeoMatch, 1000);
    }, () => setStatus('Could not access your location. Please allow location access.', 'error'));
  }

  // ── Utah County border ──
  // Source: UGRC UtahCountyBoundaries FeatureServer
  const COUNTY_URL = 'https://services1.arcgis.com/99lidPhWCzftIe9K/ArcGIS/rest/services/UtahCountyBoundaries/FeatureServer/0/query';
  const COUNTY_STYLE = { color: '#ff914d', weight: 3, opacity: 0.9, fill: false };
  let countyRing = null; // outer ring [lng,lat] used for fitBounds

  async function loadCountyBorder() {
    try {
      const params = new URLSearchParams({
        where: "NAME='UTAH'",
        outFields: 'NAME',
        outSR: 4326,
        returnGeometry: true,
        f: 'geojson'
      });
      const res = await fetch(`${COUNTY_URL}?${params}`);
      const geojson = await res.json();
      if (!geojson.features || !geojson.features.length) return;

      const feature = geojson.features[0];
      // Store outer ring for fitBounds
      const geom = feature.geometry;
      if (geom.type === 'Polygon') {
        countyRing = geom.coordinates[0];
      } else if (geom.type === 'MultiPolygon') {
        // Use the largest polygon
        let maxLen = 0;
        for (const poly of geom.coordinates) {
          if (poly[0].length > maxLen) { maxLen = poly[0].length; countyRing = poly[0]; }
        }
      }

      // Draw a single light navy wash over the whole county (avoids per-district overlap stacking)
      L.geoJSON(feature, { style: { color: 'none', weight: 0, fill: true, fillColor: '#0d2854', fillOpacity: 0.06 }, interactive: false }).addTo(map);

      // Draw the county border on the map (orange, on top)
      L.geoJSON(feature, { style: COUNTY_STYLE, interactive: false }).addTo(map);

      // Fit map to county bounds
      const coords = countyRing.map(c => [c[1], c[0]]);
      map.fitBounds(L.latLngBounds(coords).pad(0.03));
    } catch (err) {
      console.warn('County border load error:', err);
    }
  }

  // ── Clip a GeoJSON ring to the county polygon (vertex-walking) ──
  // Works on any polygon shape (convex or concave).
  // Walks each segment of the subject ring; keeps vertices inside the county,
  // inserts a binary-search crossing point whenever a segment crosses the boundary.
  function clipRingToCounty(ring) {
    if (!countyRing || !ring.length) return ring;
    const out = [];
    for (let i = 0; i < ring.length; i++) {
      const cur  = ring[i];
      const prev = ring[(i + ring.length - 1) % ring.length];
      const curIn  = pointInRing(cur[0],  cur[1],  countyRing);
      const prevIn = pointInRing(prev[0], prev[1], countyRing);
      if (prevIn && curIn)       { out.push(cur); }
      else if (prevIn && !curIn) { out.push(binaryCrossing(prev, cur, true)); }
      else if (!prevIn && curIn) { out.push(binaryCrossing(prev, cur, false)); out.push(cur); }
      // both outside → skip
    }
    return out;
  }

  function binaryCrossing(a, b, aIsInside) {
    let lo = 0, hi = 1;
    for (let s = 0; s < 20; s++) {
      const mid = (lo + hi) / 2;
      const p = [a[0] + (b[0]-a[0])*mid, a[1] + (b[1]-a[1])*mid];
      if (pointInRing(p[0], p[1], countyRing) === aIsInside) lo = mid; else hi = mid;
    }
    const t = (lo + hi) / 2;
    return [a[0] + (b[0]-a[0])*t, a[1] + (b[1]-a[1])*t];
  }

  function clipGeomToCounty(geom) {
    if (!countyRing || !geom) return null;
    const clipRings = (rings) => {
      const outer = clipRingToCounty(rings[0]);
      return outer.length >= 3 ? [outer] : null;
    };
    if (geom.type === 'Polygon') {
      const coords = clipRings(geom.coordinates);
      if (!coords) return null;
      return { type: 'Polygon', coordinates: coords };
    } else if (geom.type === 'MultiPolygon') {
      const polys = geom.coordinates.map(p => clipRings(p)).filter(Boolean);
      if (!polys.length) return null;
      return { type: 'MultiPolygon', coordinates: polys };
    }
    return null;
  }

  // ── Utah State House Districts overlay ──
  const HD_URL = 'https://services1.arcgis.com/99lidPhWCzftIe9K/ArcGIS/rest/services/UtahHouseDistricts2022to2032/FeatureServer/0/query';
  const HD_STYLE_BORDER = { color: '#0d2854', weight: 1.5, opacity: 0.85, fill: false };

  const hdLayerGroup = L.layerGroup().addTo(map);
  const hdLabelGroup = L.layerGroup().addTo(map);

  // Compute polygon centroid (average of all vertices)
  // Area-weighted centroid (shoelace formula) — gives true geographic center,
  // not just average of vertices, which fails for irregular/elongated shapes.
  function polygonCentroid(rings) {
    if (!rings || !rings.length) return null;
    const ring = rings[0];
    let area = 0, cx = 0, cy = 0;
    for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
      const xi = ring[i][0], yi = ring[i][1];
      const xj = ring[j][0], yj = ring[j][1];
      const cross = xi * yj - xj * yi;
      area += cross;
      cx   += (xi + xj) * cross;
      cy   += (yi + yj) * cross;
    }
    area /= 2;
    if (Math.abs(area) < 1e-10) return null;
    cx /= (6 * area);
    cy /= (6 * area);
    return [cy, cx]; // [lat, lng] for Leaflet
  }

  // Manual label overrides — only for districts whose true centroid falls outside Utah County
  const HD_LABEL_OVERRIDES = {
    66: [39.930, -111.800]  // HD 66 true centroid is in Juab County — force inside Utah County
  };

  // House districts that serve Utah County (per Utah County Elections)
  const UTAH_COUNTY_DISTRICTS = [50,51,52,53,54,55,56,57,58,60,61,62,63,64,65,66];

  async function loadHouseDistricts() {
    try {
      const distList = UTAH_COUNTY_DISTRICTS.join(',');
      const params = new URLSearchParams({
        where: `DIST IN (${distList})`,
        outFields: 'DIST',
        geometryPrecision: 4,
        outSR: 4326,
        returnGeometry: true,
        f: 'geojson'
      });
      const res = await fetch(`${HD_URL}?${params}`);
      const geojson = await res.json();
      if (!geojson.features) return;

      geojson.features.forEach(feature => {
        const dist = feature.properties && feature.properties.DIST;
        if (!dist) return;

        // Store rings for HD point-in-polygon lookup in showResult()
        if (feature.geometry) {
          const geom = feature.geometry;
          const coords = geom.type === 'Polygon'
            ? geom.coordinates
            : (geom.type === 'MultiPolygon'
                ? geom.coordinates.reduce((best, poly) =>
                    poly[0].length > (best ? best[0].length : 0) ? poly : best, null)
                : null);
          if (coords) hdRings[dist] = coords;
        }

        // Border only — fill is handled by a single county-wide wash to avoid overlap stacking
        const borderLayer = L.geoJSON(feature, { style: HD_STYLE_BORDER });
        hdLayerGroup.addLayer(borderLayer);

        // Place a label — use override if defined, else area-weighted centroid, else first vertex inside county
        let center = HD_LABEL_OVERRIDES[dist] || null;

        if (!center) {
          const geom = feature.geometry;
          const rings = geom.type === 'Polygon'
            ? geom.coordinates
            : (geom.type === 'MultiPolygon'
                ? geom.coordinates.reduce((best, poly) =>
                    poly[0].length > (best ? best[0].length : 0) ? poly : best, null)
                : null);
          if (!rings) return;

          center = polygonCentroid(rings);

          // If centroid is outside county, scan ring vertices for one inside
          if (center && countyRing && !pointInRing(center[1], center[0], countyRing)) {
            center = null;
            for (const pt of rings[0]) {
              if (pointInRing(pt[0], pt[1], countyRing)) {
                center = [pt[1], pt[0]]; // [lat, lng]
                break;
              }
            }
          }
        }
        if (!center) return;

        const labelIcon = L.divIcon({
          className: '',
          html: `<div class="hd-label">HD ${dist}</div>`,
          iconSize: [56, 20],
          iconAnchor: [28, 10]
        });
        const labelMarker = L.marker(center, { icon: labelIcon, interactive: false, keyboard: false });
        hdLabelGroup.addLayer(labelMarker);
      });

      // Backfill: if user searched before HD data finished loading, update the result card now
      const card = document.getElementById('resultCard');
      const precinctEl = document.getElementById('rPrecinct');
      if (card && card.classList.contains('visible') && precinctEl && precinctEl.textContent) {
        const m = precinctEl.textContent.match(/Precinct\s+(\S+)/);
        if (m) showResult(m[1], null, lastSearchLat, lastSearchLng, lastSearchDistricts);
      }
    } catch (err) {
      console.warn('House district load error:', err);
    }
  }

  function toggleHouseDistricts(show) {
    if (show) {
      if (!map.hasLayer(hdLayerGroup)) hdLayerGroup.addTo(map);
      if (!map.hasLayer(hdLabelGroup)) hdLabelGroup.addTo(map);
    } else {
      if (map.hasLayer(hdLayerGroup)) map.removeLayer(hdLayerGroup);
      if (map.hasLayer(hdLabelGroup)) map.removeLayer(hdLabelGroup);
    }
  }

  // ── Zoom-based precinct visibility ──
  const zoomHint = document.getElementById('zoomHint');

  function updatePrecinctVisibility() {
    const z = map.getZoom();
    if (z >= PRECINCT_ZOOM_THRESHOLD) {
      if (!map.hasLayer(precinctLayerGroup)) precinctLayerGroup.addTo(map);
      if (zoomHint) zoomHint.style.display = 'none';
    } else {
      if (map.hasLayer(precinctLayerGroup)) map.removeLayer(precinctLayerGroup);
      if (zoomHint) zoomHint.style.display = 'flex';
    }
  }

  map.on('zoomend', updatePrecinctVisibility);

  // ── Caucus Locations — March 17, 2026 · 6:30 PM ──
  // Green pins visible at all zoom levels
  // ─── CAUCUS LOCATIONS ────────────────────────────────────────────────────────
  // ── Boot: load county border first, then layers ──
  async function boot() {
    await loadCountyBorder();       // fetch & draw orange county border
    loadBoundaries();               // precinct polygons
    loadHouseDistricts();           // house districts (clipped to county)
updatePrecinctVisibility();     // hide precincts at initial zoom
  }
  boot();

  // Allow Enter key
  ['addrStreet', 'addrCity'].forEach(id => {
    document.getElementById(id).addEventListener('keydown', e => { if (e.key === 'Enter') searchAddress(); });
  });

  // Auto-trigger geo if URL param present
  if (new URLSearchParams(window.location.search).get('geo') === '1') {
    window.addEventListener('load', () => setTimeout(geolocate, 500));
  }

  // Auto-fill and search if address params passed from index.html
  (function() {
    const p = new URLSearchParams(window.location.search);
    const street = p.get('street');
    const city   = p.get('city');
    if (street) {
      window.addEventListener('load', () => {
        document.getElementById('addrStreet').value = street;
        if (city) document.getElementById('addrCity').value = city;
        setTimeout(searchAddress, 600);
      });
    }
  })();
</script>
</body>
</html>
