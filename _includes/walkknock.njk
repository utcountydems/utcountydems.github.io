<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ header_h1 or 'Walk & Knock Route Builder' }} – {{ nav_title or 'CaucusConnect' }} – Utah County Democratic Party</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="/assets/global.css" />
  <style>
    :root {
      --navy:#0d2854; --blue:#1a3d6e; --sky:#38b6ff; --accent:#ffde59;
      --accent2:#ff914d; --white:#fff; --offwhite:#F5F7FA;
      --text:#444443; --muted:#6b6b6a; --border:#cce8ff;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--offwhite); overflow: hidden; }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }

    /* ── NAV ── */
    nav#navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 2px solid var(--border); transition: box-shadow .3s; }
    nav#navbar.scrolled { box-shadow: 0 4px 24px rgba(13,40,84,.12); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 82px; }
    .nav-logo { display: flex; align-items: center; gap: 18px; text-decoration: none; flex-shrink: 0; margin-right: 140px; }
    .nav-logo-img { height: 56px; width: auto; display: block; object-fit: contain; }
    .nav-logo-text { display: flex; flex-direction: column; line-height: 1.1; }
    .nav-logo-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: #0d2854; white-space: nowrap; }
    .nav-logo-sub { font-size: .8rem; font-weight: 600; color: var(--muted); white-space: nowrap; letter-spacing: .03em; }
    .nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; }
    .nav-links > li { position: relative; }
    .nav-links > li > a { display: flex; align-items: center; gap: 5px; padding: 8px 14px; color: #0d2854; text-decoration: none; font-size: 1rem; font-weight: 600; border-radius: 6px; transition: background .2s, color .2s; white-space: nowrap; }
    .nav-links > li > a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-links > li.has-dropdown > a::after { content: ''; display: inline-block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; margin-left: 2px; transition: transform .2s; }
    .nav-links > li.has-dropdown:hover > a::after { transform: rotate(180deg); }
    .nav-dropdown { display: none; position: absolute; top: 100%; left: 0; min-width: 200px; background: #fff; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 8px 32px rgba(13,40,84,.12); padding: 8px 6px 6px; z-index: 1001; }
    .nav-links > li.has-dropdown:hover .nav-dropdown { display: block; }
    .nav-dropdown a { display: block; padding: 9px 14px; color: #0d2854; font-size: .95rem; font-weight: 600; text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
    .nav-dropdown a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-cta { background: #38b6ff !important; color: #fff !important; padding: 11px 24px !important; border-radius: 8px !important; font-weight: 700 !important; margin-left: 8px; }
    .nav-cta:hover { background: #1ca8f5 !important; }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
    .nav-hamburger span { display: block; width: 22px; height: 2px; background: #0d2854; border-radius: 2px; transition: .3s; }
    .mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(13,40,84,.98); flex-direction: column; align-items: center; justify-content: center; gap: 24px; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { color: #fff; font-size: 1.4rem; font-weight: 700; text-decoration: none; font-family: 'Playfair Display', serif; }
    @media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }

    /* COMPACT PAGE HEADER BAR */
    .page-header {
      background: linear-gradient(90deg, var(--navy), #071229);
      margin-top: 82px; padding: 10px 0;
      border-bottom: 2px solid var(--sky);
    }
    .page-header-inner {
      display: flex; align-items: center; gap: 12px;
    }
    .page-header .tag {
      display: inline-block; font-size: 10px; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--accent); background: rgba(255,222,89,.12);
      border: 1px solid rgba(255,222,89,.3);
      padding: 3px 10px; border-radius: 100px; white-space: nowrap;
    }
    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; font-weight: 700; color: #fff; margin: 0;
    }

    /* MAIN LAYOUT */
    .wk-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 0;
      height: calc(100vh - 82px - 42px);
    }

    /* SIDEBAR */
    .wk-sidebar {
      background: var(--white);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .sidebar-inner {
      padding: 14px;
      flex: 1;
    }

    /* Section headings */
    .section-heading {
      font-size: .72rem; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: var(--muted);
      margin-bottom: 8px; margin-top: 14px;
    }
    .section-heading:first-child { margin-top: 0; }
    .section-divider {
      border: none; border-top: 1px solid var(--border);
      margin: 14px 0;
    }

    /* Address input row */
    .addr-row {
      display: flex; gap: 6px; align-items: stretch; margin-bottom: 6px;
    }
    .addr-input {
      flex: 1; padding: 9px 12px;
      border: 2px solid var(--border); border-radius: 8px;
      font-size: .9rem; font-family: inherit; outline: none;
      transition: border-color .2s;
    }
    .addr-input:focus { border-color: var(--sky); }
    .btn-geo {
      display: flex; align-items: center; justify-content: center;
      padding: 0 10px;
      background: none; border: 2px dashed var(--border); border-radius: 8px;
      color: var(--blue); font-size: .85rem; cursor: pointer;
      transition: background .2s, border-color .2s;
      white-space: nowrap; gap: 5px; font-weight: 600; font-family: inherit;
    }
    .btn-geo:hover { background: var(--offwhite); border-color: var(--sky); }

    /* Slider rows */
    .slider-row {
      margin-bottom: 12px;
    }
    .slider-label {
      display: flex; justify-content: space-between; align-items: center;
      font-size: .85rem; font-weight: 600; color: var(--navy);
      margin-bottom: 5px;
    }
    .slider-val {
      font-size: .85rem; font-weight: 700; color: var(--sky);
      background: rgba(56,182,255,.1); border-radius: 6px;
      padding: 1px 8px;
    }
    input[type="range"] {
      width: 100%; accent-color: var(--accent2);
      cursor: pointer;
    }

    /* Party checkboxes */
    .party-checks { display: flex; flex-direction: column; gap: 7px; }
    .party-check-row {
      display: flex; align-items: center; gap: 9px;
      font-size: .88rem; font-weight: 600; color: var(--text);
      cursor: pointer;
    }
    .party-check-row input[type="checkbox"] {
      width: 15px; height: 15px; flex-shrink: 0;
      accent-color: var(--navy); cursor: pointer;
    }
    .party-dot {
      width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .dot-dem { background: #1d4ed8; }
    .dot-rep { background: #dc2626; }
    .dot-una { background: #6b7280; }

    /* Build button */
    .btn-build {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; padding: 11px;
      background: var(--navy); border: none; border-radius: 10px;
      color: #fff; font-size: 1rem; font-weight: 700;
      cursor: pointer; font-family: inherit;
      transition: background .2s; margin-top: 14px;
    }
    .btn-build:hover { background: var(--blue); }
    .btn-build:disabled { background: #9ca3af; cursor: not-allowed; }

    /* Status message */
    #wkStatus {
      margin-top: 8px; font-size: .88rem; border-radius: 8px;
      padding: 0;
    }
    #wkStatus.loading {
      padding: 10px 12px;
      background: rgba(56,182,255,.1); color: var(--blue);
    }
    #wkStatus.error {
      padding: 10px 12px;
      background: rgba(220,50,50,.08); color: #c0392b;
    }
    #wkStatus.success {
      padding: 10px 12px;
      background: rgba(22,163,74,.08); color: #15803d;
    }

    /* Stop list */
    #stopList { margin-top: 10px; }
    .stop-summary {
      font-size: .82rem; font-weight: 700; color: var(--muted);
      padding: 6px 0 8px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 8px;
    }
    .stop-item {
      display: flex; gap: 10px; align-items: flex-start;
      padding: 9px 8px; border-radius: 8px;
      margin-bottom: 4px;
      cursor: pointer;
      transition: background .15s;
    }
    .stop-item:nth-child(even) { background: rgba(245,247,250,.8); }
    .stop-item:hover { background: rgba(56,182,255,.07); }
    .stop-num {
      width: 26px; height: 26px; border-radius: 50%;
      background: var(--navy); color: #fff;
      font-size: .7rem; font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 1px;
    }
    .stop-content { flex: 1; min-width: 0; }
    .stop-addr {
      font-weight: 700; font-size: .88rem; color: var(--navy);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .stop-residents {
      display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px;
    }
    .resident-badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: .72rem; font-weight: 600;
      padding: 2px 7px; border-radius: 100px;
      white-space: nowrap;
    }
    .badge-dem { background: rgba(29,78,216,.1); color: #1d4ed8; }
    .badge-rep { background: rgba(220,38,38,.1); color: #dc2626; }
    .badge-una { background: rgba(107,114,128,.12); color: #4b5563; }
    .stop-dist {
      font-size: .72rem; color: var(--muted); margin-top: 3px;
    }

    /* MAP */
    .wk-map-wrap {
      position: relative; width: 100%; height: 100%;
    }
    #wkMap { width: 100%; height: 100%; }

    /* Satellite toggle button */
    #satToggle {
      position: absolute; top: 10px; right: 10px; z-index: 500;
      background: #fff; border: 2px solid var(--border); border-radius: 8px;
      padding: 6px 12px; font-size: .8rem; font-weight: 700;
      color: var(--navy); cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,.12);
      transition: background .2s, border-color .2s;
    }
    #satToggle:hover { background: var(--offwhite); border-color: var(--sky); }
    #satToggle.active { background: var(--navy); color: #fff; border-color: var(--navy); }
  </style>
</head>
<body>

{% include "partials/nav.njk" %}

<!-- COMPACT PAGE HEADER -->
<div class="page-header">
  <div class="container">
    <div class="page-header-inner">
      <span class="tag">Canvassing</span>
      <h1>{{ header_h1 or 'Walk &amp; Knock Route Builder' }}</h1>
    </div>
  </div>
</div>

<!-- MAIN LAYOUT -->
<div class="wk-layout">

  <!-- SIDEBAR -->
  <aside class="wk-sidebar">
    <div class="sidebar-inner">

      <!-- Starting Location -->
      <div class="section-heading">Starting Location</div>
      <div class="addr-row">
        <input type="text" id="startAddr" class="addr-input"
          placeholder="Enter address or intersection…"
          aria-label="Starting address" />
        <button class="btn-geo" id="btnGeo" title="Use my current location">
          <i class="fa-solid fa-location-crosshairs"></i>
        </button>
      </div>

      <hr class="section-divider" />

      <!-- Route Settings -->
      <div class="section-heading">Route Settings</div>

      <!-- Number of Doors -->
      <div class="slider-row">
        <div class="slider-label">
          <span>Number of Doors</span>
          <span class="slider-val" id="numDoorsVal">20</span>
        </div>
        <input type="range" id="numDoors" min="5" max="75" value="20" step="5"
          aria-label="Number of doors" />
      </div>

      <!-- Party Affiliation -->
      <div class="slider-row">
        <div class="slider-label" style="margin-bottom:8px;">
          <span>Party Affiliation</span>
        </div>
        <div class="party-checks">
          <label class="party-check-row">
            <input type="checkbox" class="party-check" value="Dem" checked />
            <span class="party-dot dot-dem"></span>
            Democrat
          </label>
          <label class="party-check-row">
            <input type="checkbox" class="party-check" value="Rep" checked />
            <span class="party-dot dot-rep"></span>
            Republican
          </label>
          <label class="party-check-row">
            <input type="checkbox" class="party-check" value="Una" checked />
            <span class="party-dot dot-una"></span>
            Unaffiliated
          </label>
        </div>
      </div>

      <!-- Walking Radius -->
      <div class="slider-row">
        <div class="slider-label">
          <span>Walking Radius</span>
          <span class="slider-val" id="radiusVal">0.5 mi</span>
        </div>
        <input type="range" id="radiusSlider" min="1" max="15" value="5" step="1"
          aria-label="Walking radius" />
      </div>

      <!-- Build button -->
      <button class="btn-build" id="btnBuild">
        <i class="fa-solid fa-route"></i> Build Route
      </button>

      <!-- Status -->
      <div id="wkStatus"></div>

      <!-- Stop List -->
      <div id="stopList"></div>

    </div>
  </aside>

  <!-- MAP -->
  <div class="wk-map-wrap">
    <div id="wkMap"></div>
    <button id="satToggle" title="Toggle satellite imagery">Satellite</button>
  </div>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
