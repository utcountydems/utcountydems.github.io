  // ── Scroll the sidebar so the candidates panel top is visible ────────────
  function scrollSidebarToCandidates() {
    const sidebar = document.querySelector('.sidebar');
    const panel   = document.getElementById('sidebarCandidates');
    if (!sidebar || !panel) return;
    // getBoundingClientRect gives viewport-relative positions; adjust by current scroll
    const sidebarTop = sidebar.getBoundingClientRect().top;
    const panelTop   = panel.getBoundingClientRect().top;
    sidebar.scrollTo({ top: sidebar.scrollTop + (panelTop - sidebarTop) - 10, behavior: 'smooth' });
  }

  // ── Build + show candidates inside the sidebar panel ────────────────────
  function showCandidates(hdNum, sdNum, ssbNum, congNum, precinctId) {
    const panel = document.getElementById('sidebarCandidates');
    const grid  = document.getElementById('sidebarCandsGrid');
    if (!panel || !grid) return;

    // Build all possible groups, then keep only races with a Democratic candidate
    const allGroups = [];
    if (hdNum)  allGroups.push({ label: `State House District ${hdNum}`,              icon: 'fa-house',            cands: CANDIDATES.house[String(hdNum)]        || null });
    if (sdNum && SD_UP_2026.has(sdNum))
                allGroups.push({ label: `State Senate District ${sdNum}`,             icon: 'fa-landmark',         cands: CANDIDATES.senate[String(sdNum)]       || null });
    allGroups.push(              { label: 'County Commissioner — Seat A (County-wide)', icon: 'fa-building-columns', cands: CANDIDATES.countywideA });
    allGroups.push(              { label: 'County Commissioner — Seat B (County-wide)', icon: 'fa-building-columns', cands: CANDIDATES.countywideB });
    if (ssbNum && SSB_UP_2026.has(ssbNum))
                allGroups.push({ label: `State School Board Dist. ${ssbNum}`,         icon: 'fa-school',           cands: CANDIDATES.schoolBoard[String(ssbNum)]  || null });
    if (congNum)     allGroups.push({ label: `Congressional District ${congNum}`,                   icon: 'fa-flag-usa',         cands: CANDIDATES.congressional[congNum]          || null, tbd: true });

    // Show all ballot races; sort candidates within each group by last name
    const lastName = name => name.trim().split(/\s+/).slice(-1)[0].toLowerCase();
    const groups = allGroups.map(g => ({
      ...g,
      cands: g.cands && g.cands.length > 0
        ? [...g.cands].sort((a, b) => lastName(a.name).localeCompare(lastName(b.name)))
        : null
    }));

    let html = '';
    for (const g of groups) {
      html += `<div class="scand-group">`;
      html += `<div class="scand-group-label"><i class="fa-solid ${g.icon}"></i>${g.label}</div>`;
      if (g.cands) {
        for (const c of g.cands) {
          const isBoth = c.method.includes('+') || c.method.toLowerCase().includes('both');
          html += `<div class="scand-card">`;
          html += `<div class="scand-name">${c.name}</div>`;
          html += `<span class="scand-tag${isBoth ? ' both' : ''}">${c.method}</span>`;
          if (c.phone) html += `<a href="tel:${c.phone}" class="scand-contact"><i class="fa-solid fa-phone"></i>${c.phone}</a>`;
          if (c.email) html += `<a href="mailto:${c.email}" class="scand-contact"><i class="fa-solid fa-envelope"></i>${c.email}</a>`;
          if (c.website) html += `<a href="${c.website}" target="_blank" rel="noopener" class="scand-contact"><i class="fa-solid fa-globe"></i>${c.website.replace(/^https?:\/\//, '')}</a>`;
          if (c.socials) html += `<a href="${c.socials}" target="_blank" rel="noopener" class="scand-contact"><i class="fa-solid fa-link"></i>${c.socials.replace(/^https?:\/\//, '')}</a>`;
          if (c.multiCounty) html += `<div class="scand-multicounty"><i class="fa-solid fa-map"></i> Multi-county district</div>`;
          html += `</div>`;
        }
      } else if (g.tbd) {
        html += `<div class="scand-none"><i class="fa-solid fa-clock" style="margin-right:5px;color:#64748b;"></i>TBD — Filing opens March 9–13. Check back for updates.</div>`;
      } else {
        html += `<div class="scand-none"><i class="fa-solid fa-circle-exclamation" style="margin-right:5px;color:#b04a00;"></i>No Democratic candidate has filed for this race.</div>`;
      }
      html += `</div>`;
    }

    grid.innerHTML = html;
    panel.style.display = 'block';

    // Show the "See Your Candidates" row in the result card
    const candsRow = document.getElementById('rCandsRow');
    if (candsRow) candsRow.style.display = 'flex';
  }

