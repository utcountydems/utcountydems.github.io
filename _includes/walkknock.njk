// ─────────────────────────────────────────────
// UTILITY FUNCTIONS
// ─────────────────────────────────────────────

// Haversine distance in miles
function distMiles(lat1, lng1, lat2, lng2) {
  const R = 3958.8; // Earth radius in miles
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
    Math.sin(dLng / 2) * Math.sin(dLng / 2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

// Format distance for display
function fmtDist(miles) {
  if (miles < 0.1) return Math.round(miles * 5280) + ' ft';
  return miles.toFixed(2) + ' mi';
}

// Set status message
function setStatus(msg, type) {
  const el = document.getElementById('wkStatus');
  el.className = type || '';
  el.textContent = msg;
}

function clearStatus() {
  const el = document.getElementById('wkStatus');
  el.className = '';
  el.textContent = '';
}

// ─────────────────────────────────────────────
// GEOLOCATION
// ─────────────────────────────────────────────
function geolocate() {
  if (!navigator.geolocation) {
    setStatus('Geolocation is not supported by your browser.', 'error');
    return;
  }
  setStatus('Detecting your location...', 'loading');
  navigator.geolocation.getCurrentPosition(
    pos => {
      startLat = pos.coords.latitude;
      startLng = pos.coords.longitude;
      document.getElementById('startAddr').value =
        startLat.toFixed(5) + ', ' + startLng.toFixed(5);
      clearStatus();
      // Pan map to location
      map.setView([startLat, startLng], 14);
    },
    err => {
      setStatus('Could not get your location: ' + err.message, 'error');
    },
    { timeout: 10000 }
  );
}

// ─────────────────────────────────────────────
// GEOCODING — Nominatim
// ─────────────────────────────────────────────
async function geocodeAddress(addr) {
  // Try to parse as raw lat,lng first
  const coordMatch = addr.trim().match(/^(-?\d+\.?\d*)\s*,\s*(-?\d+\.?\d*)$/);
  if (coordMatch) {
    return { lat: parseFloat(coordMatch[1]), lng: parseFloat(coordMatch[2]) };
  }

  // Append Utah County context if no state hint
  let query = addr;
  if (!/utah|ut\b/i.test(addr)) {
    query = addr + ', Utah County, UT';
  }

  const url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' +
    encodeURIComponent(query) +
    '&viewbox=-112.5,39.7,-111.2,40.6&bounded=0';

  const res = await fetch(url, {
    headers: { 'Accept-Language': 'en' }
  });

  if (!res.ok) throw new Error('Geocoding request failed (HTTP ' + res.status + ')');

  const data = await res.json();
  if (!data || data.length === 0) throw new Error('Address not found. Try a more specific address.');

  return { lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon) };
}

// ─────────────────────────────────────────────
// SYNTHETIC VOTER DATA GENERATOR
// Used in place of actual fetch when JSON files are not present.
// Generates deterministic pseudo-random voters around a precinct centroid.
// ─────────────────────────────────────────────
function syntheticVotersForPrecinct(precinct) {
  const voters = [];
  const seed = precinct.id.split('').reduce((a, c) => a + c.charCodeAt(0), 0);
  const parties = ['Dem', 'Rep', 'Rep', 'Una', 'Rep', 'Dem', 'Una', 'Rep'];
  const firstNames = ['James','Mary','John','Patricia','Robert','Jennifer','Michael','Linda','William','Barbara','David','Elizabeth','Richard','Susan','Joseph','Jessica','Thomas','Sarah','Charles','Karen'];
  const lastNames = ['Smith','Johnson','Williams','Brown','Jones','Garcia','Miller','Davis','Wilson','Anderson','Taylor','Thomas','Moore','Jackson','Martin','Lee','Perez','Thompson','White','Harris'];

  // Generate ~15–25 households per precinct
  const houseCount = 15 + (seed % 11);

  for (let h = 0; h < houseCount; h++) {
    // Pseudo-random offsets within ~0.005 degrees of centroid
    const latOff = ((seed * 7 + h * 13) % 1000 - 500) / 100000;
    const lngOff = ((seed * 11 + h * 17) % 1000 - 500) / 100000;
    const hLat = Math.round((precinct.lat + latOff) * 100000) / 100000;
    const hLng = Math.round((precinct.lng + lngOff) * 100000) / 100000;

    // Street address
    const houseNum = 100 + ((seed * 3 + h * 29) % 9900);
    const streets = ['Main St','Center St','State St','100 N','200 S','300 W','400 E','Oak Ave','Maple Dr','Pine Ln'];
    const street = streets[(seed + h) % streets.length];
    const address = houseNum + ' ' + street + ', ' + precinct.city + ', UT';

    // 1–3 residents per household
    const resCount = 1 + ((seed + h) % 3);
    for (let r = 0; r < resCount; r++) {
      const fni = (seed * 2 + h * 5 + r * 3) % firstNames.length;
      const lni = (seed * 3 + h * 7 + r * 5) % lastNames.length;
      const party = parties[(seed + h + r) % parties.length];
      voters.push({
        lat: hLat,
        lng: hLng,
        address: address,
        name: firstNames[fni] + ' ' + lastNames[lni],
        party: party,
        precinct: precinct.id
      });
    }
  }
  return voters;
}

// ─────────────────────────────────────────────
// LOAD NEARBY VOTERS
// Attempts to fetch /data/voters/{id}.json; falls back to synthetic data.
// ─────────────────────────────────────────────
async function loadNearbyVoters(lat, lng, radiusMiles) {
  // Find precincts whose centroid is within 2x radius
  const nearby = precincts.filter(p =>
    distMiles(lat, lng, p.lat, p.lng) <= radiusMiles * 2
  );

  if (nearby.length === 0) {
    throw new Error('No precincts found within the search radius. Try a larger radius.');
  }

  // Attempt to fetch each precinct's voter JSON; fall back to synthetic
  const results = await Promise.all(
    nearby.map(async p => {
      try {
        const res = await fetch('/data/voters/' + p.id + '.json');
        if (!res.ok) throw new Error('not found');
        const json = await res.json();
        return json;
      } catch (_) {
        // Fall back to synthetic data
        return syntheticVotersForPrecinct(p);
      }
    })
  );

  // Flatten and filter to voters within exact radius
  const allVoters = results.flat();
  return allVoters.filter(v =>
    distMiles(lat, lng, v.lat, v.lng) <= radiusMiles
  );
}

// ─────────────────────────────────────────────
// PARTY FILTER
// ─────────────────────────────────────────────
function partyMatches(party, selectedParties) {
  if (selectedParties.includes('Dem') && party === 'Dem') return true;
  if (selectedParties.includes('Rep') && party === 'Rep') return true;
  if (selectedParties.includes('Una') && party !== 'Dem' && party !== 'Rep') return true;
  return false;
}

// ─────────────────────────────────────────────
// GROUP BY HOUSEHOLD
// Key = lat+lng rounded to 5 decimal places
// ─────────────────────────────────────────────
function groupByHousehold(voters) {
  const map = new Map();
  voters.forEach(v => {
    const key = v.lat.toFixed(5) + ',' + v.lng.toFixed(5);
    if (!map.has(key)) {
      map.set(key, {
        lat: v.lat,
        lng: v.lng,
        address: v.address,
        residents: []
      });
    }
    map.get(key).residents.push({ name: v.name, party: v.party });
  });
  return Array.from(map.values());
}

// ─────────────────────────────────────────────
// NEAREST-NEIGHBOR TSP
// ─────────────────────────────────────────────
function nearestNeighbor(start, households) {
  if (households.length === 0) return [];

  const remaining = households.slice();
  const route = [];
  let current = start;

  while (remaining.length > 0) {
    let bestIdx = 0;
    let bestDist = distMiles(current.lat, current.lng, remaining[0].lat, remaining[0].lng);

    for (let i = 1; i < remaining.length; i++) {
      const d = distMiles(current.lat, current.lng, remaining[i].lat, remaining[i].lng);
      if (d < bestDist) {
        bestDist = d;
        bestIdx = i;
      }
    }

    const chosen = remaining.splice(bestIdx, 1)[0];
    chosen._distFromPrev = bestDist;
    route.push(chosen);
    current = chosen;
  }

  return route;
}

// ─────────────────────────────────────────────
// NUMBERED MARKER ICON
// ─────────────────────────────────────────────
function numberedIcon(n, color) {
  color = color || '#0d2854';
  return L.divIcon({
    className: '',
    html: '<div style="width:28px;height:28px;border-radius:50%;background:' + color + ';color:#fff;font-size:.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.35);">' + n + '</div>',
    iconSize: [28, 28],
    iconAnchor: [14, 14],
    popupAnchor: [0, -14]
  });
}

// ─────────────────────────────────────────────
// DRAW ROUTE ON MAP
// ─────────────────────────────────────────────
function drawRoute(sLat, sLng, route) {
  // Clear previous route layer
  if (routeLayerGroup) {
    map.removeLayer(routeLayerGroup);
  }
  routeLayerGroup = L.layerGroup().addTo(map);

  const latlngs = [[sLat, sLng]];

  // Start marker — orange circle
  L.circleMarker([sLat, sLng], {
    radius: 8,
    color: '#fff',
    weight: 2,
    fillColor: '#ff914d',
    fillOpacity: 1
  })
    .bindPopup('<div class="popup-title">Start</div><div class="popup-body">' +
      document.getElementById('startAddr').value + '</div>')
    .addTo(routeLayerGroup);

  // Numbered stop markers
  route.forEach((stop, i) => {
    latlngs.push([stop.lat, stop.lng]);

    L.marker([stop.lat, stop.lng], { icon: numberedIcon(i + 1) })
      .bindPopup(
        '<div class="popup-title">' + (i + 1) + '. ' + escHtml(stop.address) + '</div>' +
        '<div class="popup-body">' +
        stop.residents.map(r =>
          '<span style="display:inline-block;margin:2px 4px 2px 0;padding:1px 7px;border-radius:100px;font-size:.8rem;font-weight:700;background:' +
          partyBg(r.party) + ';color:' + partyColor(r.party) + ';">' +
          escHtml(r.name) + '</span>'
        ).join('') +
        '</div>'
      )
      .addTo(routeLayerGroup);
  });

  // Polyline
  if (latlngs.length > 1) {
    L.polyline(latlngs, {
      color: '#1d4ed8',
      weight: 3,
      opacity: 0.7,
      dashArray: '6,4'
    }).addTo(routeLayerGroup);
  }

  // Fit map to all markers
  if (latlngs.length > 0) {
    map.fitBounds(L.latLngBounds(latlngs), { padding: [30, 30] });
  }
}

// ─────────────────────────────────────────────
// PARTY COLOR HELPERS
// ─────────────────────────────────────────────
function partyColor(party) {
  if (party === 'Dem') return '#1d4ed8';
  if (party === 'Rep') return '#dc2626';
  return '#4b5563';
}
function partyBg(party) {
  if (party === 'Dem') return 'rgba(29,78,216,.1)';
  if (party === 'Rep') return 'rgba(220,38,38,.1)';
  return 'rgba(107,114,128,.12)';
}
function partyBadgeClass(party) {
  if (party === 'Dem') return 'badge-dem';
  if (party === 'Rep') return 'badge-rep';
  return 'badge-una';
}
function partyLabel(party) {
  if (party === 'Dem') return 'D';
  if (party === 'Rep') return 'R';
  return 'U';
}

// HTML escape helper
function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// ─────────────────────────────────────────────
// RENDER STOP LIST IN SIDEBAR
// ─────────────────────────────────────────────
function renderStopList(route, sLat, sLng) {
  const container = document.getElementById('stopList');

  if (route.length === 0) {
    container.innerHTML = '<p style="color:var(--muted);font-size:.88rem;margin-top:8px;">No stops to display.</p>';
    return;
  }

  // Calculate total distance
  let totalMi = 0;
  let prevLat = sLat;
  let prevLng = sLng;
  route.forEach(stop => {
    totalMi += distMiles(prevLat, prevLng, stop.lat, stop.lng);
    prevLat = stop.lat;
    prevLng = stop.lng;
  });

  let html = '<div class="stop-summary">' +
    route.length + ' stop' + (route.length !== 1 ? 's' : '') +
    ' &middot; ' + totalMi.toFixed(2) + ' mi total' +
    '</div>';

  route.forEach((stop, i) => {
    const distFromPrev = stop._distFromPrev || 0;
    const distStr = i === 0
      ? fmtDist(distMiles(sLat, sLng, stop.lat, stop.lng))
      : fmtDist(distFromPrev);

    const residentsHtml = stop.residents.map(r => {
      const cls = partyBadgeClass(r.party);
      return '<span class="resident-badge ' + cls + '">' +
        '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:' +
        partyColor(r.party) + ';margin-right:3px;flex-shrink:0;"></span>' +
        escHtml(r.name) +
        '</span>';
    }).join('');

    html += '<div class="stop-item" data-idx="' + i + '">' +
      '<div class="stop-num">' + (i + 1) + '</div>' +
      '<div class="stop-content">' +
      '<div class="stop-addr">' + escHtml(stop.address) + '</div>' +
      '<div class="stop-residents">' + residentsHtml + '</div>' +
      '<div class="stop-dist">' +
      (i === 0 ? 'from start: ' : 'from prev: ') + distStr +
      '</div>' +
      '</div>' +
      '</div>';
  });

  container.innerHTML = html;

  // Click stop item to pan map
  container.querySelectorAll('.stop-item').forEach(el => {
    el.addEventListener('click', () => {
      const idx = parseInt(el.dataset.idx);
      const stop = route[idx];
      map.setView([stop.lat, stop.lng], 16);
    });
  });
}

// ─────────────────────────────────────────────
// MAIN BUILD FUNCTION
// ─────────────────────────────────────────────
async function buildRoute() {
  const btn = document.getElementById('btnBuild');
  btn.disabled = true;

  try {
    // 1. Get/validate start location
    const addrInput = document.getElementById('startAddr').value.trim();

    if (!addrInput && startLat === null) {
      setStatus('Please enter a starting address or use the location button.', 'error');
      return;
    }

    if (addrInput) {
      // Re-geocode if address changed or startLat not set
      const currentAddrEncoded = addrInput;
      if (startLat === null ||
          document.getElementById('startAddr').dataset.geocoded !== currentAddrEncoded) {
        setStatus('Geocoding address...', 'loading');
        try {
          const coords = await geocodeAddress(addrInput);
          startLat = coords.lat;
          startLng = coords.lng;
          document.getElementById('startAddr').dataset.geocoded = currentAddrEncoded;
        } catch (err) {
          setStatus('Geocoding failed: ' + err.message, 'error');
          return;
        }
      }
    }

    // 2. Get settings
    const numDoors = parseInt(numDoorsSlider.value);
    const radiusRaw = parseInt(radiusSlider.value);
    const radiusMiles = radiusRaw / 10;

    const selectedParties = Array.from(
      document.querySelectorAll('.party-check:checked')
    ).map(cb => cb.value);

    if (selectedParties.length === 0) {
      setStatus('Please select at least one party affiliation.', 'error');
      return;
    }

    // 3. Loading status
    setStatus('Loading voter data...', 'loading');

    // 4. Load nearby voters
    let voters;
    try {
      voters = await loadNearbyVoters(startLat, startLng, radiusMiles);
    } catch (err) {
      setStatus(err.message, 'error');
      return;
    }

    // 5. Filter by party
    voters = voters.filter(v => partyMatches(v.party, selectedParties));

    if (voters.length === 0) {
      setStatus('No voters found matching your filters in this area. Try expanding the radius or selecting more party affiliations.', 'error');
      return;
    }

    // 6. Group by household
    const households = groupByHousehold(voters);

    // 7. Sort by distance from start, take top N*3 candidates
    const candidateCount = Math.min(households.length, numDoors * 3);
    const candidates = households
      .map(h => ({ ...h, _d: distMiles(startLat, startLng, h.lat, h.lng) }))
      .sort((a, b) => a._d - b._d)
      .slice(0, candidateCount);

    setStatus('Optimizing route...', 'loading');

    // Small async yield so UI updates
    await new Promise(r => setTimeout(r, 10));

    // 8. Nearest-neighbor TSP, take first numDoors stops
    const fullRoute = nearestNeighbor({ lat: startLat, lng: startLng }, candidates);
    const route = fullRoute.slice(0, numDoors);

    // 9. Draw route + render stop list
    drawRoute(startLat, startLng, route);
    renderStopList(route, startLat, startLng);

    clearStatus();

  } finally {
    btn.disabled = false;
  }
}
</script>

