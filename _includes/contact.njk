  // ── Helpers ──
  function cityFromAddress(addr) {
    if (!addr) return '';
    const parts = addr.split(',');
    return parts.length > 1 ? parts[1].trim() : '';
  }

  function partyKey(p) {
    if (p === 'Dem') return 'Dem';
    if (p === 'Rep') return 'Rep';
    return 'Una';
  }

  function partyBadge(p) {
    const k = partyKey(p);
    const cls = k === 'Dem' ? 'pb-dem' : k === 'Rep' ? 'pb-rep' : 'pb-una';
    const label = k === 'Dem' ? 'Dem' : k === 'Rep' ? 'Rep' : 'Una';
    return `<span class="party-badge ${cls}">${label}</span>`;
  }

  function scoreBar(v) {
    const pct = Math.min(100, Math.max(0, (parseFloat(v) / 10) * 100));
    return `<div class="score-cell"><div class="score-bar"><div class="score-fill" style="width:${pct}%"></div></div>${parseFloat(v).toFixed(1)}</div>`;
  }

  function escHtml(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Load all voter data ──
  async function loadAllVoters() {
    const total = precincts.length;
    let done = 0;
    const BATCH = 20;

    for (let i = 0; i < precincts.length; i += BATCH) {
      const batch = precincts.slice(i, i + BATCH);
      const results = await Promise.all(batch.map(async p => {
        try {
          const r = await fetch(`/assets/voters/${p.id}.json`);
          return r.ok ? await r.json() : [];
        } catch { return []; }
      }));
      results.forEach(voters => {
        voters.forEach(v => {
          v.city = cityFromAddress(v.address);
          allVoters.push(v);
        });
      });
      done += batch.length;
      const pct = Math.round((done / total) * 100);
      document.getElementById('progressFill').style.width = pct + '%';
      document.getElementById('progressLabel').textContent =
        `Loading… ${done} of ${total} precincts (${allVoters.length.toLocaleString()} voters)`;
    }

    // Hide progress, enable controls
    document.getElementById('progressWrap').style.display = 'none';
    document.getElementById('btnGenerate').disabled = false;
    document.querySelectorAll('.filter-select').forEach(s => s.disabled = false);
    document.getElementById('resultsCount').textContent =
      `${allVoters.length.toLocaleString()} voters loaded — set filters and click Generate List`;

    populateDropdowns();
  }

  function populateDropdowns() {
    const sets = { hd: new Set(), sd: new Set(), ssbd: new Set(), lsbd: new Set(), city: new Set() };
    allVoters.forEach(v => {
      if (v.hd)   sets.hd.add(v.hd);
      if (v.sd)   sets.sd.add(v.sd);
      if (v.ssbd) sets.ssbd.add(v.ssbd);
      if (v.lsbd) sets.lsbd.add(v.lsbd);
      if (v.city) sets.city.add(v.city);
    });

    function fill(id, vals, numeric) {
      const el = document.getElementById(id);
      const sorted = [...vals].sort(numeric
        ? (a, b) => parseInt(a) - parseInt(b)
        : (a, b) => a.localeCompare(b));
      sorted.forEach(v => {
        const o = document.createElement('option');
        o.value = v; o.textContent = v;
        el.appendChild(o);
      });
    }

    fill('fHD',   sets.hd,   true);
    fill('fSD',   sets.sd,   true);
    fill('fSSBD', sets.ssbd, true);
    fill('fLSBD', sets.lsbd, true);
    fill('fCity', sets.city, false);
  }

  // ── Filter ──
  function applyFilters() {
    const hd      = document.getElementById('fHD').value;
    const sd      = document.getElementById('fSD').value;
    const ssbd    = document.getElementById('fSSBD').value;
    const lsbd    = document.getElementById('fLSBD').value;
    const city    = document.getElementById('fCity').value;
    const minScore = parseFloat(document.getElementById('fVScore').value);
    const parties = new Set(
      [...document.querySelectorAll('.party-chk:checked')].map(c => c.value)
    );

    filtered = allVoters.filter(v => {
      if (!v.phone) return false;
      if (hd   && v.hd   !== hd)   return false;
      if (sd   && v.sd   !== sd)   return false;
      if (ssbd && v.ssbd !== ssbd) return false;
      if (lsbd && v.lsbd !== lsbd) return false;
      if (city && v.city !== city) return false;
      if (!parties.has(partyKey(v.party))) return false;
      if (parseFloat(v.v_score) < minScore) return false;
      return true;
    });

    currentPage = 0;
    sortDir = 'asc'; sortField = 'name';
    renderTable();
  }

  // ── Sort ──
  function sortTable(field) {
    if (sortField === field) {
      sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    } else {
      sortField = field; sortDir = 'asc';
    }

    filtered.sort((a, b) => {
      let va = a[field] ?? '', vb = b[field] ?? '';
      if (field === 'v_score') { va = parseFloat(va) || 0; vb = parseFloat(vb) || 0; }
      else if (field === 'hd' || field === 'sd') { va = parseInt(va) || 0; vb = parseInt(vb) || 0; }
      else { va = String(va).toLowerCase(); vb = String(vb).toLowerCase(); }
      return sortDir === 'asc' ? (va < vb ? -1 : va > vb ? 1 : 0) : (va > vb ? -1 : va < vb ? 1 : 0);
    });

    // Update header classes
    document.querySelectorAll('.voter-table th').forEach(th => {
      th.classList.remove('asc', 'desc');
    });
    const ths = document.querySelectorAll('.voter-table th');
    const fields = ['name','phone','address','city','party','hd','sd','v_score'];
    const idx = fields.indexOf(field);
    if (idx >= 0) ths[idx].classList.add(sortDir);

    currentPage = 0;
    renderTable();
  }

  // ── Render ──
  function renderTable() {
    const wrap     = document.getElementById('tableWrap');
    const stateBox = document.getElementById('stateBox');
    const countEl  = document.getElementById('resultsCount');
    const exportBtn = document.getElementById('btnExport');

    if (filtered.length === 0) {
      wrap.style.display = 'none';
      stateBox.innerHTML = '<i class="fa-solid fa-filter-circle-xmark"></i><p>No voters match your filters. Try adjusting your criteria.</p>';
      stateBox.style.display = 'block';
      document.getElementById('pagination').innerHTML = '';
      countEl.textContent = '0 results';
      exportBtn.disabled = true;
      return;
    }

    stateBox.style.display = 'none';
    wrap.style.display = 'block';
    exportBtn.disabled = false;

    const start = currentPage * PAGE_SIZE;
    const page  = filtered.slice(start, start + PAGE_SIZE);

    document.getElementById('tableBody').innerHTML = page.map(v => `
      <tr>
        <td>${escHtml(v.name)}</td>
        <td>${escHtml(v.phone || '—')}</td>
        <td>${escHtml(v.address)}</td>
        <td>${escHtml(v.city)}</td>
        <td>${partyBadge(v.party)}</td>
        <td>${escHtml(v.hd || '—')}</td>
        <td>${escHtml(v.sd || '—')}</td>
        <td>${scoreBar(v.v_score)}</td>
      </tr>
    `).join('');

    const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
    countEl.innerHTML = `<strong>${filtered.length.toLocaleString()}</strong> results · page ${currentPage + 1} of ${totalPages}`;

    renderPagination(totalPages);
  }

  function renderPagination(totalPages) {
    const el = document.getElementById('pagination');
    if (totalPages <= 1) { el.innerHTML = ''; return; }

    const WINDOW = 2;
    let html = `<button class="pg-btn" onclick="goPage(${currentPage - 1})" ${currentPage === 0 ? 'disabled' : ''}>‹</button>`;

    for (let i = 0; i < totalPages; i++) {
      if (i === 0 || i === totalPages - 1 || Math.abs(i - currentPage) <= WINDOW) {
        html += `<button class="pg-btn ${i === currentPage ? 'active' : ''}" onclick="goPage(${i})">${i + 1}</button>`;
      } else if (Math.abs(i - currentPage) === WINDOW + 1) {
        html += `<span style="padding:0 4px;color:var(--muted);">…</span>`;
      }
    }

    html += `<button class="pg-btn" onclick="goPage(${currentPage + 1})" ${currentPage === totalPages - 1 ? 'disabled' : ''}>›</button>`;
    el.innerHTML = html;
  }

  function goPage(n) {
    currentPage = n;
    renderTable();
    document.querySelector('.results-panel').scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Export CSV ──
  function exportCSV() {
    const headers = ['Name','Phone','Address','City','Party','HD','SD','V-Score'];
    const rows = filtered.map(v => [
      v.name, v.phone || '', v.address, v.city, v.party, v.hd || '', v.sd || '', v.v_score
    ]);
    const csv = [headers, ...rows]
      .map(r => r.map(c => `"${String(c ?? '').replace(/"/g,'""')}"`).join(','))
      .join('\n');
    const blob = new URL(URL.createObjectURL(new Blob([csv], { type: 'text/csv' })));
    const a = Object.assign(document.createElement('a'), { href: blob.href, download: 'contact-list.csv' });
    a.click();
    URL.revokeObjectURL(blob.href);
  }

  // ── Boot ──
  loadAllVoters();
</script>
</body>
</html>
