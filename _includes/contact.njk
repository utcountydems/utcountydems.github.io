<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/assets/global.css" />
  <style>
    :root { --navy:#0d2854; --blue:#1a3d6e; --sky:#38b6ff; --accent:#ffde59; --accent2:#ff914d; --white:#fff; --offwhite:#F5F7FA; --text:#444443; --muted:#6b6b6a; --border:#cce8ff; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--offwhite); overflow-x: hidden; }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }

    nav#navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 2px solid var(--border); transition: box-shadow .3s; }
    nav#navbar.scrolled { box-shadow: 0 4px 24px rgba(13,40,84,.12); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 82px; }
    .nav-logo { display: flex; align-items: center; gap: 18px; text-decoration: none; flex-shrink: 0; margin-right: 140px; }
    .nav-logo-img { height: 56px; width: auto; display: block; object-fit: contain; }
    .nav-logo-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: #0d2854; white-space: nowrap; text-decoration: none; }
    .nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; }
    .nav-links > li { position: relative; }
    .nav-links > li > a { display: flex; align-items: center; gap: 5px; padding: 8px 14px; color: #0d2854; text-decoration: none; font-size: 1rem; font-weight: 600; border-radius: 6px; transition: background .2s, color .2s; white-space: nowrap; }
    .nav-links > li > a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-links > li.has-dropdown > a::after { content: ''; display: inline-block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; margin-left: 2px; transition: transform .2s; }
    .nav-links > li.has-dropdown:hover > a::after { transform: rotate(180deg); }
    .nav-dropdown { display: none; position: absolute; top: 100%; left: 0; min-width: 200px; background: #fff; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 8px 32px rgba(13,40,84,.12); padding: 8px 6px 6px; z-index: 1001; }
    .nav-links > li.has-dropdown:hover .nav-dropdown { display: block; }
    .nav-dropdown a { display: block; padding: 9px 14px; color: #0d2854; font-size: .95rem; font-weight: 600; text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
    .nav-dropdown a:hover { background: var(--offwhite); color: #38b6ff; }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
    .nav-hamburger span { display: block; width: 22px; height: 2px; background: #0d2854; border-radius: 2px; transition: .3s; }
    .mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(13,40,84,.98); flex-direction: column; align-items: center; justify-content: center; gap: 24px; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { color: #fff; font-size: 1.4rem; font-weight: 700; text-decoration: none; font-family: 'Playfair Display', serif; }
    @media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }

    .page-header { background: linear-gradient(135deg, #0d2854, #071229); padding: 48px 0 32px; margin-top: 82px; }
    .page-header .tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
    .page-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 700; color: #fff; margin-bottom: 8px; }
    .page-header p { color: rgba(255,255,255,.7); font-size: 1rem; max-width: 680px; line-height: 1.6; }

    /* ── TOOL LAYOUT ── */
    .tool-wrap { display: grid; grid-template-columns: 270px 1fr; min-height: calc(100vh - 82px - 160px); }

    /* ── FILTER PANEL ── */
    .filter-panel {
      background: var(--white);
      border-right: 1px solid var(--border);
      padding: 24px 20px;
      position: sticky; top: 82px;
      height: calc(100vh - 82px);
      overflow-y: auto;
    }
    .filter-panel h3 { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--navy); margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
    .filter-group { margin-bottom: 18px; }
    .filter-label { font-size: .75rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; display: block; }
    .filter-select {
      width: 100%; padding: 8px 10px;
      border: 1px solid var(--border); border-radius: 8px;
      font-size: .88rem; color: var(--text); font-family: inherit;
      background: var(--white); cursor: pointer;
    }
    .filter-select:focus { outline: none; border-color: var(--sky); }
    .filter-select:disabled { background: var(--offwhite); color: var(--muted); cursor: not-allowed; }

    .party-checks { display: flex; flex-direction: column; gap: 7px; }
    .party-check-row { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: .88rem; color: var(--text); user-select: none; }
    .party-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }

    .slider-wrap { padding: 2px 0; }
    .filter-slider { width: 100%; accent-color: var(--navy); cursor: pointer; }
    .slider-labels { display: flex; justify-content: space-between; font-size: .72rem; color: var(--muted); margin-top: 3px; }

    .btn-generate {
      width: 100%; padding: 11px 16px;
      background: var(--navy); color: #fff;
      font-weight: 700; font-size: .9rem; font-family: inherit;
      border: none; border-radius: 10px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: background .2s; margin-top: 4px;
    }
    .btn-generate:hover:not(:disabled) { background: var(--blue); }
    .btn-generate:disabled { background: var(--muted); cursor: not-allowed; }

    /* ── RESULTS PANEL ── */
    .results-panel { padding: 24px; overflow: hidden; }

    .results-bar {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 10px; margin-bottom: 16px;
    }
    .results-count { font-size: .9rem; color: var(--muted); font-weight: 600; }
    .results-count strong { color: var(--navy); }

    .btn-export {
      padding: 8px 16px; background: var(--sky); color: #fff;
      font-weight: 700; font-size: .82rem; font-family: inherit;
      border: none; border-radius: 8px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      transition: background .2s;
    }
    .btn-export:hover { background: #1aacf5; }
    .btn-export:disabled { background: var(--border); cursor: not-allowed; }

    /* Loading */
    .progress-wrap { margin-bottom: 14px; }
    .progress-track { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--sky); width: 0%; transition: width .15s; border-radius: 2px; }
    .progress-label { font-size: .78rem; color: var(--muted); margin-top: 5px; }

    /* Table */
    .table-wrap { overflow-x: auto; background: var(--white); border: 1px solid var(--border); border-radius: 12px; }
    .voter-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
    .voter-table th {
      padding: 11px 14px; text-align: left;
      font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
      color: var(--muted); background: var(--offwhite); border-bottom: 1px solid var(--border);
      white-space: nowrap; cursor: pointer; user-select: none;
    }
    .voter-table th:hover { color: var(--navy); }
    .voter-table th.asc .sort-arrow::after  { content: ' ↑'; color: var(--sky); }
    .voter-table th.desc .sort-arrow::after { content: ' ↓'; color: var(--sky); }
    .voter-table th:not(.asc):not(.desc) .sort-arrow::after { content: ' ↕'; opacity: .35; }
    .voter-table td { padding: 10px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .voter-table tr:last-child td { border-bottom: none; }
    .voter-table tbody tr:hover td { background: rgba(56,182,255,.04); }

    .party-badge { display: inline-block; font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 100px; }
    .pb-dem { background: rgba(29,78,216,.1); color: #1d4ed8; }
    .pb-rep { background: rgba(220,38,38,.1); color: #dc2626; }
    .pb-una { background: rgba(100,116,139,.12); color: #475569; }

    .score-cell { display: flex; align-items: center; gap: 8px; }
    .score-bar { width: 50px; height: 5px; background: var(--border); border-radius: 3px; overflow: hidden; flex-shrink: 0; }
    .score-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--sky), var(--navy)); }

    /* Pagination */
    .pagination { display: flex; align-items: center; justify-content: center; gap: 5px; margin-top: 18px; flex-wrap: wrap; }
    .pg-btn {
      min-width: 34px; height: 34px; padding: 0 10px;
      border: 1px solid var(--border); border-radius: 7px;
      background: var(--white); color: var(--navy);
      font-size: .82rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: background .15s, border-color .15s;
    }
    .pg-btn:hover:not(:disabled) { background: var(--offwhite); border-color: var(--sky); }
    .pg-btn.active { background: var(--navy); color: #fff; border-color: var(--navy); }
    .pg-btn:disabled { opacity: .35; cursor: not-allowed; }

    /* Empty / initial states */
    .state-box { text-align: center; padding: 60px 20px; color: var(--muted); }
    .state-box i { font-size: 2.8rem; color: var(--border); display: block; margin-bottom: 16px; }
    .state-box p { font-size: .95rem; line-height: 1.6; max-width: 380px; margin: 0 auto; }

    @media (max-width: 900px) {
      .tool-wrap { grid-template-columns: 1fr; }
      .filter-panel { position: static; height: auto; border-right: none; border-bottom: 1px solid var(--border); }
    }
  </style>
</head>
<body>

{% include "partials/nav.njk" %}
{% include "partials/dropdown-bar.njk" %}

<div class="page-header">
  <div class="container">
    <span class="tag">{{ header_tag }}</span>
    <h1>{{ header_h1 }}</h1>
    <p>Filter voter records by district, city, party, and voter score to build a targeted contact list.</p>
  </div>
</div>

<div class="tool-wrap">

  <!-- ── FILTER PANEL ── -->
  <aside class="filter-panel">
    <h3><i class="fa-solid fa-sliders" style="color:var(--sky);margin-right:8px;"></i>Filters</h3>

    <div class="filter-group">
      <label class="filter-label">House District (HD)</label>
      <select id="fHD" class="filter-select" disabled><option value="">All Districts</option></select>
    </div>

    <div class="filter-group">
      <label class="filter-label">Senate District (SD)</label>
      <select id="fSD" class="filter-select" disabled><option value="">All Districts</option></select>
    </div>

    <div class="filter-group">
      <label class="filter-label">State School Board (SSBD)</label>
      <select id="fSSBD" class="filter-select" disabled><option value="">All Districts</option></select>
    </div>

    <div class="filter-group">
      <label class="filter-label">Local School Board (LSBD)</label>
      <select id="fLSBD" class="filter-select" disabled><option value="">All Districts</option></select>
    </div>

    <div class="filter-group">
      <label class="filter-label">City</label>
      <select id="fCity" class="filter-select" disabled><option value="">All Cities</option></select>
    </div>

    <div class="filter-group">
      <label class="filter-label">Party</label>
      <div class="party-checks">
        <label class="party-check-row">
          <input type="checkbox" class="party-chk" value="Dem" checked />
          <span class="party-dot" style="background:#1d4ed8;"></span> Democrat
        </label>
        <label class="party-check-row">
          <input type="checkbox" class="party-chk" value="Rep" checked />
          <span class="party-dot" style="background:#dc2626;"></span> Republican
        </label>
        <label class="party-check-row">
          <input type="checkbox" class="party-chk" value="Una" checked />
          <span class="party-dot" style="background:#64748b;"></span> Unaffiliated
        </label>
      </div>
    </div>

    <div class="filter-group">
      <label class="filter-label">Min V-Score: <strong id="vScoreDisplay">0</strong></label>
      <div class="slider-wrap">
        <input type="range" id="fVScore" class="filter-slider" min="0" max="10" step="0.5" value="0"
               oninput="document.getElementById('vScoreDisplay').textContent=this.value" />
        <div class="slider-labels"><span>0</span><span>10</span></div>
      </div>
    </div>

    <button id="btnGenerate" class="btn-generate" onclick="applyFilters()" disabled>
      <i class="fa-solid fa-list-check"></i> Generate List
    </button>
  </aside>

  <!-- ── RESULTS PANEL ── -->
  <main class="results-panel">

    <div id="progressWrap" class="progress-wrap">
      <div class="progress-track"><div id="progressFill" class="progress-fill"></div></div>
      <div id="progressLabel" class="progress-label">Loading voter data…</div>
    </div>

    <div class="results-bar">
      <div class="results-count" id="resultsCount"></div>
      <button id="btnExport" class="btn-export" onclick="exportCSV()" disabled>
        <i class="fa-solid fa-download"></i> Export CSV
      </button>
    </div>

    <div id="stateBox" class="state-box">
      <i class="fa-solid fa-person-booth"></i>
      <p>Set your filters above and click <strong>Generate List</strong> to view voter contacts.</p>
    </div>

    <div id="tableWrap" class="table-wrap" style="display:none;">
      <table class="voter-table">
        <thead>
          <tr>
            <th onclick="sortTable('name')">Name <span class="sort-arrow"></span></th>
            <th onclick="sortTable('phone')">Phone <span class="sort-arrow"></span></th>
            <th onclick="sortTable('address')">Address <span class="sort-arrow"></span></th>
            <th onclick="sortTable('city')">City <span class="sort-arrow"></span></th>
            <th onclick="sortTable('party')">Party <span class="sort-arrow"></span></th>
            <th onclick="sortTable('hd')">HD <span class="sort-arrow"></span></th>
            <th onclick="sortTable('sd')">SD <span class="sort-arrow"></span></th>
            <th onclick="sortTable('v_score')">V-Score <span class="sort-arrow"></span></th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>

    <div id="pagination" class="pagination"></div>

  </main>
</div>

{% include "partials/footer.njk" %}

