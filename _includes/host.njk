<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ meta_description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/assets/global.css" />
  <style>
    :root { --navy:#0d2854; --blue:#1a3d6e; --sky:#38b6ff; --accent:#ffde59; --accent2:#ff914d; --white:#fff; --offwhite:#F5F7FA; --text:#444443; --muted:#6b6b6a; --border:#cce8ff; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--offwhite); overflow-x: hidden; }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    .section { padding: 40px 0; }
    .section-alt { background: var(--white); }
    .tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent2); margin-bottom: 12px; }
    .section-sub { font-size: 1.1rem; color: var(--muted); max-width: none; line-height: 1.7; text-wrap: balance; }
nav#navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 2px solid var(--border); transition: box-shadow .3s; }
nav#navbar.scrolled { box-shadow: 0 4px 24px rgba(13,40,84,.12); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; height: 82px; }
.nav-logo { display: flex; align-items: center; gap: 18px; text-decoration: none; flex-shrink: 0; margin-right: 140px; }
.nav-logo-img { height: 56px; width: auto; display: block; object-fit: contain; }
.nav-logo-text { display: flex; flex-direction: column; line-height: 1.1; }
.nav-logo-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: #0d2854; white-space: nowrap; }
.nav-logo-sub { font-size: .8rem; font-weight: 600; color: var(--muted); white-space: nowrap; letter-spacing: .03em; }
.nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; }
.nav-links > li { position: relative; }
.nav-links > li > a { display: flex; align-items: center; gap: 5px; padding: 8px 14px; color: #0d2854; text-decoration: none; font-size: 1rem; font-weight: 600; border-radius: 6px; transition: background .2s, color .2s; white-space: nowrap; }
.nav-links > li > a:hover { background: var(--offwhite); color: #38b6ff; }
.nav-links > li.has-dropdown > a::after { content: ''; display: inline-block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; margin-left: 2px; transition: transform .2s; }
.nav-links > li.has-dropdown:hover > a::after { transform: rotate(180deg); }
.nav-dropdown { display: none; position: absolute; top: 100%; left: 0; min-width: 200px; background: #fff; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 8px 32px rgba(13,40,84,.12); padding: 8px 6px 6px; z-index: 1001; }
.nav-links > li.has-dropdown:hover .nav-dropdown { display: block; }
.nav-dropdown a { display: block; padding: 9px 14px; color: #0d2854; font-size: .95rem; font-weight: 600; text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
.nav-dropdown a:hover { background: var(--offwhite); color: #38b6ff; }
.nav-cta { background: #38b6ff !important; color: #fff !important; padding: 11px 24px !important; border-radius: 8px !important; font-weight: 700 !important; margin-left: 8px; }
.nav-cta:hover { background: #1ca8f5 !important; }
.nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
.nav-hamburger span { display: block; width: 22px; height: 2px; background: #0d2854; border-radius: 2px; transition: .3s; }
.mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(13,40,84,.98); flex-direction: column; align-items: center; justify-content: center; gap: 24px; }
.mobile-menu.open { display: flex; }
.mobile-menu a { color: #fff; font-size: 1.4rem; font-weight: 700; text-decoration: none; font-family: 'Playfair Display', serif; }
@media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }
    .page-header { background: linear-gradient(135deg, #0d2854, #071229); padding: 60px 0 28px; margin-top: 82px; }
    .page-header .tag { color: var(--accent); }
    .page-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #fff; margin-bottom: 12px; }
    .page-header p { color: rgba(255,255,255,.7); font-size: 1.1rem; max-width: none; line-height: 1.7; text-wrap: balance; }
    .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-top: 28px; }
    .info-card { background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 30px 28px; transition: box-shadow .2s, transform .2s; }
    .info-card:hover { box-shadow: 0 8px 28px rgba(13,40,84,.1); transform: translateY(-4px); }
    .info-card .card-icon { width: 52px; height: 52px; border-radius: 12px; background: linear-gradient(135deg, var(--navy), var(--blue)); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.2rem; margin-bottom: 16px; }
    .info-card h4 { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--navy); margin-bottom: 8px; }
    .info-card p { font-size: .92rem; color: var(--muted); line-height: 1.7; }
    .info-card a { color: var(--sky); font-weight: 600; }
    .advert-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 48px; align-items: start; }
    .advert-item { display: flex; gap: 16px; align-items: flex-start; padding: 24px; background: var(--white); border: 1px solid var(--border); border-radius: 12px; }
    .advert-item i { font-size: 1.4rem; color: var(--sky); flex-shrink: 0; margin-top: 2px; }
    .advert-item h4 { font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .advert-item p { font-size: .91rem; color: var(--muted); line-height: 1.6; }
    .advert-item a { color: var(--sky); font-weight: 600; }
    .checklist-section { margin-top: 28px; }
    .checklist-group { background: var(--white); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 12px; overflow: hidden; }
    .checklist-group-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; cursor: pointer; transition: background .2s; }
    .checklist-group-header:hover { background: var(--offwhite); }
    .checklist-group-header .header-left { display: flex; align-items: center; gap: 12px; }
    .checklist-group-header i { color: var(--sky); font-size: 1.1rem; }
    .checklist-group-header h4 { font-weight: 700; color: var(--navy); font-size: 1rem; }
    .checklist-group-header .toggle-icon { color: var(--sky); font-size: .9rem; transition: transform .25s; }
    .checklist-group.open .toggle-icon { transform: rotate(45deg); }
    .checklist-group-body { display: none; padding: 0 24px 20px; border-top: 1px solid var(--border); }
    .checklist-group.open .checklist-group-body { display: block; }
    .checklist-group-body ul { margin-top: 14px; display: flex; flex-direction: column; gap: 10px; }
    .checklist-group-body ul li { display: flex; align-items: flex-start; gap: 10px; font-size: .92rem; color: var(--muted); line-height: 1.6; }
    .checklist-group-body ul li::before { content: '☐'; font-size: 1rem; color: var(--sky); flex-shrink: 0; margin-top: 1px; }
    .timeline { margin-top: 28px; }
    .timeline-item { display: flex; gap: 24px; align-items: flex-start; padding: 22px 0; border-bottom: 1px solid var(--border); }
    .timeline-item:last-child { border-bottom: none; }
    .timeline-time { flex-shrink: 0; width: 110px; font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: var(--navy); }
    .timeline-dot { flex-shrink: 0; width: 12px; height: 12px; border-radius: 50%; background: var(--accent); margin-top: 6px; box-shadow: 0 0 0 4px rgba(255,222,89,.2); }
    .timeline-desc { font-size: .95rem; color: var(--muted); line-height: 1.6; }
    .timeline-desc strong { color: var(--text); }
    .callout { background: linear-gradient(135deg, var(--navy), var(--blue)); border-radius: 16px; padding: 36px; margin-top: 48px; display: flex; gap: 20px; align-items: flex-start; }
    .callout i { font-size: 1.8rem; color: var(--accent); flex-shrink: 0; margin-top: 2px; }
    .callout h3 { font-family: 'Playfair Display', serif; color: #fff; font-size: 1.3rem; margin-bottom: 8px; }
    .callout p { color: rgba(255,255,255,.75); font-size: .97rem; line-height: 1.65; }
    .callout a { color: var(--accent); font-weight: 700; text-decoration: none; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: var(--navy); font-weight: 700; font-size: 1rem; padding: 14px 28px; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 20px rgba(255,222,89,.35); transition: transform .2s, box-shadow .2s; margin-top: 20px; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(255,222,89,.45); background: #ffd633; }
    .callout .btn-primary { color: var(--navy); } /* override .callout a which would make text yellow-on-yellow */
    .callout .btn-primary i { color: var(--navy); } /* override .callout i which would make icon yellow-on-yellow */
    footer { background: #070f1f; padding: 20px 0 12px; border-top: 1px solid rgba(255,255,255,.06); }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,.08); margin-bottom: 14px; }
    .footer-brand p { color: rgba(255,255,255,.45); font-size: .85rem; line-height: 1.6; margin-top: 6px; max-width: 280px; }
    .footer-socials { display: flex; gap: 8px; margin-top: 10px; }
    .footer-social { width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,.07); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,.55); font-size: .9rem; text-decoration: none; transition: background .2s, color .2s; }
    .footer-social:hover { background: var(--sky); color: #fff; }
    .footer-col h4 { font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 8px; }
    .footer-col a { display: block; color: rgba(255,255,255,.6); font-size: .85rem; text-decoration: none; margin-bottom: 5px; transition: color .2s; }
    .footer-col a:hover { color: #fff; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; color: rgba(255,255,255,.3); font-size: .82rem; }
    .footer-bottom a { color: rgba(255,255,255,.4); text-decoration: none; }
    .footer-bottom a:hover { color: rgba(255,255,255,.7); }
    @media (max-width: 900px) { .advert-grid { grid-template-columns: 1fr; } .footer-inner { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .nav-links { display: none; } .nav-hamburger { display: flex; } .footer-inner { grid-template-columns: 1fr; gap: 16px; } .footer-bottom { flex-direction: column; text-align: center; } }
  </style>
</head>
<body>

{% include "partials/nav.njk" %}

<div class="page-header">
  <div class="container">
    <span class="tag">{{ header_tag }}</span>
    <h1>{{ header_h1 }}</h1>
    <p>{{ header_subtitle }}</p>
  </div>
</div>

<!-- TRAINING & PREPARATION -->
<section class="section section-alt">
  <div class="container">
    <span class="tag">{{ training_section.tag }}</span>
    <h2 class="section-title">{{ training_section.heading }}</h2>
    <p class="section-sub">{{ training_section.sub }}</p>
    <div class="info-grid">
      {% for card in training_section.cards %}
      <div class="info-card">
        <div class="card-icon"><i class="{{ card.icon }}"></i></div>
        <h4>{{ card.title }}</h4>
        <p>{{ card.desc | safe }}</p>
      </div>
      {% endfor %}
    </div>
    <div class="callout">
      <i class="fa-solid fa-circle-info"></i>
      <div>
        <h3>{{ training_section.callout.heading }}</h3>
        <p>{{ training_section.callout.body | safe }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ADVERTISING YOUR CAUCUS -->
<section class="section">
  <div class="container">
    <span class="tag">{{ advert_section.tag }}</span>
    <h2 class="section-title">{{ advert_section.heading }}</h2>
    <p class="section-sub">{{ advert_section.sub }}</p>
    <div class="advert-grid">
      {% for item in advert_section.items %}
      <div class="advert-item">
        <i class="{{ item.icon }}"></i>
        <div>
          <h4>{{ item.title }}</h4>
          <p>{{ item.desc | safe }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- VENUE CHECKLIST -->
<section class="section section-alt">
  <div class="container">
    <span class="tag">{{ venue_checklist.tag }}</span>
    <h2 class="section-title">{{ venue_checklist.heading }}</h2>
    <p class="section-sub">{{ venue_checklist.sub }}</p>
    <div class="checklist-section">
      {% for group in venue_checklist.groups %}
      <div class="checklist-group{% if loop.first %} open{% endif %}">
        <div class="checklist-group-header" onclick="toggleChecklist(this)">
          <div class="header-left">
            <i class="{{ group.icon }}"></i>
            <h4>{{ group.title }}</h4>
          </div>
          <i class="fa-solid fa-plus toggle-icon"></i>
        </div>
        <div class="checklist-group-body">
          <ul>
            {% for item in group.items %}
            <li>{{ item.text }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- BALLOT & VOTING PROCEDURES -->
<section class="section">
  <div class="container">
    <span class="tag">{{ ballot_section.tag }}</span>
    <h2 class="section-title">{{ ballot_section.heading }}</h2>
    <p class="section-sub">{{ ballot_section.sub }}</p>
    <div class="info-grid">
      {% for card in ballot_section.cards %}
      <div class="info-card">
        <div class="card-icon"><i class="{{ card.icon }}"></i></div>
        <h4>{{ card.title }}</h4>
        <p>{{ card.desc | safe }}</p>
      </div>
      {% endfor %}
    </div>
    <div class="callout">
      <i class="fa-solid fa-book-open"></i>
      <div>
        <h3>{{ ballot_section.callout.heading }}</h3>
        <p>{{ ballot_section.callout.body | safe }}</p>
      </div>
    </div>
  </div>
</section>

<!-- DAY-OF TIMELINE -->
<section class="section section-alt">
  <div class="container">
    <span class="tag">{{ timeline_section.tag }}</span>
    <h2 class="section-title">{{ timeline_section.heading }}</h2>
    <p class="section-sub">{{ timeline_section.sub }}</p>
    <div class="timeline">
      {% for item in timeline_section.items %}
      <div class="timeline-item">
        <div class="timeline-time">{{ item.time }}</div>
        <div class="timeline-dot"></div>
        <div class="timeline-desc">{{ item.desc | safe }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CONTACT FOR HELP -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <span class="tag">{{ contact_section.tag }}</span>
    <h2 class="section-title">{{ contact_section.heading }}</h2>
    <p class="section-sub">{{ contact_section.sub }}</p>
    <div class="callout" style="margin-top:32px;">
      <i class="fa-solid fa-phone-volume"></i>
      <div>
        <h3>{{ contact_section.callout.heading }}</h3>
        <p>{{ contact_section.callout.body | safe }}</p>
        <a href="{{ contact_section.callout.btn_url }}" class="btn-primary"><i class="fa-solid fa-envelope"></i> {{ contact_section.callout.btn_text }}</a>
      </div>
    </div>
  </div>
</section>

{% include "partials/footer.njk" %}

<script>
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
  });
  function toggleMenu() { document.getElementById('mobileMenu').classList.toggle('open'); }
  function toggleChecklist(header) {
    header.parentElement.classList.toggle('open');
  }
</script>
</body>
</html>
